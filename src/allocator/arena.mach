use std.types.bool;
use std.types.result;
use std.types.size;
use std.types.string;

use a: std.allocator;
use mem: std.memory;

# std.allocator.arena: a simple bump allocator backed by another allocator.
# ---
# properties:
# - allocation is O(1)
# - free is a no-op (optionally rolls back only the most recent allocation)
# - resize is best-effort in-place for the most recent allocation; otherwise it alloc+copies

# Arena: simple bump allocator state backed by another allocator.
# ---
# backing: allocator used for backing storage.
# buf: backing buffer pointer.
# cap: backing buffer capacity.
# off: current allocation offset.
# last_off: offset of most recent allocation for rollback/resize.
# last_size: size of most recent allocation for rollback/resize.
pub rec Arena {
    backing: a.Allocator;

    buf: ptr;
    cap: usize;
    off: usize;

    last_off:  usize;
    last_size: usize;
}

fun align_up(v: usize, align: usize) usize {
    if (align <= 1) { ret v; }

    val r: usize = v % align;
    if (r == 0) { ret v; }
    ret v + (align - r);
}

fun min_usize(a: usize, b: usize) usize {
    if (a < b) { ret a; }
    ret b;
}

# Create and initialize an Arena with cap bytes using backing allocator.
# ---
# backing: allocator used to provide backing storage for the arena.
# cap: if 0 produces an empty arena that does not allocate backing storage.
# ret: Ok(Arena) or Err(AllocError) on failure to allocate backing buffer.
pub fun init(backing: a.Allocator, cap: usize) Result[Arena, a.AllocError] {
    var ar: Arena;
    ar.backing   = backing;
    ar.buf       = nil;
    ar.cap       = cap;
    ar.off       = 0;
    ar.last_off  = 0;
    ar.last_size = 0;

    if (cap == 0) {
        ret ok[Arena, a.AllocError](ar);
    }

    # arena memory is typically page-aligned already; request a conservative alignment.
    val p: ptr = backing.alloc_fn(backing.ctx, cap, 16);
    if (p == nil) {
        ret err[Arena, a.AllocError]("out of memory");
    }

    ar.buf = p;
    ret ok[Arena, a.AllocError](ar);
}

# Free any backing storage associated with the arena.
# ---
# ret: true if the backing allocator reports success; no-op for nil or empty arenas.
pub fun (this: *Arena) deinit() bool {
    if (this == nil) { ret true; }
    if (this.buf == nil || this.cap == 0) { ret true; }

    val ok_free: bool = this.backing.free_fn(this.backing.ctx, this.buf, this.cap, 16);
    this.buf = nil;
    this.cap = 0;
    this.off = 0;
    this.last_off  = 0;
    this.last_size = 0;
    ret ok_free;
}

# Reset the arena to an empty state without freeing backing storage; existing allocations become invalid.
pub fun (this: *Arena) reset() {
    if (this == nil) { ret; }
    this.off = 0;
    this.last_off  = 0;
    this.last_size = 0;
}

fun arena_alloc(ctx: ptr, size: usize, align: usize) ptr {
    if (ctx == nil) { ret nil; }

    val this: *Arena = ctx::*Arena;
    if (size == 0) { ret nil; }
    if (this.buf == nil || this.cap == 0) { ret nil; }

    val start: usize = align_up(this.off, align);
    if (start > this.cap) { ret nil; }

    val end: usize = start + size;
    if (end > this.cap) { ret nil; }

    this.last_off  = start;
    this.last_size = size;
    this.off       = end;

    ret (this.buf::usize + start)::ptr;
}

fun arena_resize(ctx: ptr, p: ptr, old_size: usize, new_size: usize, align: usize) ptr {
    if (ctx == nil) { ret nil; }

    val this: *Arena = ctx::*Arena;

    if (p == nil) {
        ret arena_alloc(ctx, new_size, align);
    }

    if (new_size == 0) {
        # arena does not reclaim; callers should drop the pointer.
        ret nil;
    }

    # try in-place if this is the most recent allocation
    val last_ptr: ptr = (this.buf::usize + this.last_off)::ptr;
    if (this.buf != nil && p == last_ptr && old_size == this.last_size) {
        val end: usize = this.last_off + new_size;
        if (end <= this.cap) {
            this.off       = end;
            this.last_size = new_size;
            ret p;
        }
    }

    # fallback: alloc+copy
    val q: ptr = arena_alloc(ctx, new_size, align);
    if (q == nil) { ret nil; }

    val n: usize = min_usize(old_size, new_size);
    mem.raw_copy(q, p, n);
    ret q;
}

fun arena_free(ctx: ptr, p: ptr, size: usize, align: usize) bool {
    if (ctx == nil) { ret false; }

    val this: *Arena = ctx::*Arena;
    if (p == nil) { ret true; }

    # best-effort rollback for last allocation
    val last_ptr: ptr = (this.buf::usize + this.last_off)::ptr;
    if (this.buf != nil && p == last_ptr && size == this.last_size) {
        this.off = this.last_off;
        this.last_off  = 0;
        this.last_size = 0;
    }

    ret true;
}

# Return an a.Allocator view that delegates to this arena.
# ---
# ret: Allocator view that delegates to this arena.
pub fun (this: *Arena) allocator() a.Allocator {
    var al: a.Allocator;
    al.ctx = this::ptr;
    al.alloc_fn  = arena_alloc;
    al.resize_fn = arena_resize;
    al.free_fn   = arena_free;
    ret al;
}

# --- tests ---

test "arena: init with zero capacity succeeds" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 0);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: init with capacity allocates backing storage" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 1024);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: allocator returns functional allocator" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 4096);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();

    var alloc: a.Allocator = ar.allocator();
    val alloc_r: Result[*i64, a.AllocError] = alloc.alloc[i64](4);
    if (alloc_r.is_err()) { ret 1; }
    val p: *i64 = alloc_r.unwrap_ok();
    if (p == nil) { ret 1; }

    p[0] = 100;
    p[1] = 200;
    if (p[0] != 100) { ret 1; }
    if (p[1] != 200) { ret 1; }

    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: multiple allocations bump offset" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 4096);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    var alloc: a.Allocator = ar.allocator();

    val r1: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r1.is_err()) { ret 1; }
    val p1: *i64 = r1.unwrap_ok();

    val r2: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r2.is_err()) { ret 1; }
    val p2: *i64 = r2.unwrap_ok();

    # p2 should be after p1 in memory
    if (p2::usize <= p1::usize) { ret 1; }

    p1[0] = 111;
    p2[0] = 222;
    if (p1[0] != 111) { ret 1; }
    if (p2[0] != 222) { ret 1; }

    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: reset clears allocations" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 4096);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    var alloc: a.Allocator = ar.allocator();

    # allocate some memory
    val r1: Result[*i64, a.AllocError] = alloc.alloc[i64](100);
    if (r1.is_err()) { ret 1; }
    val p1: *i64 = r1.unwrap_ok();

    # reset
    ar.reset();

    # allocate again - should get same (or similar) address
    val r2: Result[*i64, a.AllocError] = alloc.alloc[i64](100);
    if (r2.is_err()) { ret 1; }
    val p2: *i64 = r2.unwrap_ok();

    # after reset, new allocation should start from beginning
    # so p2 should be at or near the same address as p1
    if (p2 != p1) { ret 1; }

    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: free is noop for non-last allocation" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 4096);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    var alloc: a.Allocator = ar.allocator();

    val r1: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r1.is_err()) { ret 1; }
    val p1: *i64 = r1.unwrap_ok();

    val r2: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r2.is_err()) { ret 1; }
    val p2: *i64 = r2.unwrap_ok();

    # free p1 (not the last allocation) - should be noop
    val ok_free: bool = alloc.free[i64](p1, 2);
    if (!ok_free) { ret 1; }

    # p2 should still be accessible
    p2[0] = 999;
    if (p2[0] != 999) { ret 1; }

    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: free last allocation rolls back" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 4096);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    var alloc: a.Allocator = ar.allocator();

    val r1: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r1.is_err()) { ret 1; }
    val p1: *i64 = r1.unwrap_ok();

    val r2: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r2.is_err()) { ret 1; }
    val p2: *i64 = r2.unwrap_ok();

    # free p2 (last allocation) - should roll back
    val ok_free: bool = alloc.free[i64](p2, 2);
    if (!ok_free) { ret 1; }

    # next allocation should reuse p2's space
    val r3: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r3.is_err()) { ret 1; }
    val p3: *i64 = r3.unwrap_ok();

    if (p3 != p2) { ret 1; }

    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: resize last allocation in-place" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 4096);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    var alloc: a.Allocator = ar.allocator();

    val r1: Result[*i64, a.AllocError] = alloc.alloc[i64](2);
    if (r1.is_err()) { ret 1; }
    val p1: *i64 = r1.unwrap_ok();
    p1[0] = 111;
    p1[1] = 222;

    # resize in-place (should succeed for last allocation)
    val r2: Result[*i64, a.AllocError] = alloc.resize[i64](p1, 2, 4);
    if (r2.is_err()) { ret 1; }
    val p2: *i64 = r2.unwrap_ok();

    # should be same pointer for in-place resize
    if (p2 != p1) { ret 1; }

    # original data preserved
    if (p2[0] != 111) { ret 1; }
    if (p2[1] != 222) { ret 1; }

    # can use new space
    p2[2] = 333;
    p2[3] = 444;
    if (p2[2] != 333) { ret 1; }
    if (p2[3] != 444) { ret 1; }

    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: deinit on nil arena succeeds" {
    var ar: Arena;
    ar.buf = nil;
    ar.cap = 0;
    ar.off = 0;
    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}

test "arena: allocation respects alignment" {
    var backing: a.Allocator = a.page_allocator();
    val r: Result[Arena, a.AllocError] = init(backing, 4096);
    if (r.is_err()) { ret 1; }
    var ar: Arena = r.unwrap_ok();
    var alloc: a.Allocator = ar.allocator();

    # allocate 1 byte
    val r1: Result[ptr, a.AllocError] = alloc.alloc_bytes(1, 1);
    if (r1.is_err()) { ret 1; }

    # allocate 8 bytes with 8-byte alignment
    val r2: Result[ptr, a.AllocError] = alloc.alloc_bytes(8, 8);
    if (r2.is_err()) { ret 1; }
    val p2: ptr = r2.unwrap_ok();

    # check alignment
    val addr: usize = p2::usize;
    if ((addr % 8) != 0) { ret 1; }

    val ok: bool = ar.deinit();
    if (!ok) { ret 1; }
    ret 0;
}
