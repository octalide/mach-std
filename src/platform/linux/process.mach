# stable linux platform process module.
#
# selects an arch-specific backend and exposes minimal process primitives.

$if ($mach.build.target.arch.id == $mach.arch.x86_64.id) {
    use impl: std.platform.linux.x86_64.process;
}
$or {
    $error("std.platform.linux.process: unsupported arch");
}

pub fun terminate(code: i64) {
    impl.terminate(code);
}

pub fun abort() {
    impl.abort();
}
