# time

# realtime: read the wall-clock time.
# ---
# out: pointer to Timespec to populate
# ret: 0 on success, negative errno on failure
pub fun realtime(out: *Timespec) i64 {
    var ts: impl.timespec = impl.timespec{tv_sec: 0, tv_nsec: 0};
    val r: i64 = impl.clock_gettime(impl.CLOCK_REALTIME, ?ts);
    if (r < 0) {
        out.sec = 0;
        out.nsec = 0;
        ret r;
    }
    out.sec = ts.tv_sec;
    out.nsec = ts.tv_nsec;
    ret 0;
}

# sentinels
fwd NOT_FOUND: shared.NOT_FOUND;

# monotonic: read the monotonic clock.
# ---
# out: pointer to Timespec to populate
# ret: 0 on success, negative errno on failure
pub fun monotonic(out: *Timespec) i64 {
    var ts: impl.timespec = impl.timespec{tv_sec: 0, tv_nsec: 0};
    val r: i64 = impl.clock_gettime(impl.CLOCK_MONOTONIC, ?ts);
    if (r < 0) {
        out.sec = 0;
        out.nsec = 0;
        ret r;
    }
    out.sec = ts.tv_sec;
    out.nsec = ts.tv_nsec;
    ret 0;
}

# error
pub fun message(code: i64) str {
    if (code >= 0) {
        ret "not an error";
    }
    ret impl.error_message(code);
}
