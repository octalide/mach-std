# std.system.os: cross-platform OS interface.
#
# forwards the portable intersection of all supported targets.
# for platform-specific functionality, import the target module
# directly (e.g. std.system.os.linux).

use std.types.string.str;

use shared: std.system.os.shared;

$if ($mach.target.os == $mach.os.linux) {
    use impl: std.system.os.linux;
}
$or ($mach.target.os == $mach.os.darwin) {
    use impl: std.system.os.darwin;
}
$or ($mach.target.os == $mach.os.windows) {
    use impl: std.system.os.windows;
}
$or {
    $error("std.system.os: unsupported target");
}

# abstract types
fwd Timespec: shared.Timespec;

