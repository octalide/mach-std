# linux process primitives for std.system.platform.
#
# this is intentionally minimal: enough for runtime entry and hard termination.

$if ($mach.build.target.arch.id != $mach.arch.x86_64.id) {
    $error("std.system.platform.linux.process: unsupported arch");
}

pub fun terminate(code: i64) {
    masm {
        mov rax, 60
        mov rdi, code
        syscall
        hlt
    }
}

pub fun abort() {
    terminate(255);
}
