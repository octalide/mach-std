# std.system.os.darwin.aarch64: aarch64-specific darwin OS primitives.
#
# provides page_size and pipe which require arch-specific assembly.
# everything else is in shared.mach.

use shared: std.system.os.darwin.shared;

$if ($mach.target.os != $mach.os.darwin) {
    $error("std.system.os.darwin.aarch64: requires darwin target");
}

$if ($mach.target.arch != $mach.arch.aarch64) {
    $error("std.system.os.darwin.aarch64: requires aarch64 target");
}

pub fun page_size() usize {
    ret 16384;
}

# pipe: create a unidirectional pipe.
#
# darwin pipe() syscall returns two fds in x0/x1. the syscall DSL only
# captures x0, so this uses raw asm with a global to capture both.
# ---
# fds: pointer to two i32s; fds[0] = read end, fds[1] = write end
# ret: 0 on success, or negative errno
pub fun pipe(fds: *i32) i64 {
    var result: i64 = 0;
    asm aarch64 {
        mov x9, x0
        mov x16, 42
        svc 0x80
        b.cs 1f
        str w0, [x9]
        str w1, [x9, 4]
        mov x0, 0
        b 2f
    1:
        neg x0, x0
    2:
        str x0, {result}
    }
    ret result;
}

