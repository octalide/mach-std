# std.system.os.darwin.x86_64: complete darwin x86_64 OS interface.
#
# raw syscall wrappers, kernel ABI types, and all OS primitives for
# the darwin x86_64 target. uses the portable syscall DSL which the
# compiler translates to the syscall instruction with BSD class offset.

use std.types.size;
use std.types.bool;
use std.types.string;

use c:      std.system.os.darwin.x86_64.constants;
use shared:    std.system.os.darwin.shared;
use os_shared: std.system.os.shared;

$if ($mach.build.target.os.id != $mach.os.darwin.id) {
    $error("std.system.os.darwin.x86_64: requires darwin target");
}

$if ($mach.build.target.arch.id != $mach.arch.x86_64.id) {
    $error("std.system.os.darwin.x86_64: requires x86_64 target");
}

# kernel ABI types (identical layout on darwin x86_64 and aarch64)

pub rec stat_t {
    st_dev:        i32;
    st_mode:       u16;
    st_nlink:      u16;
    st_ino:        u64;
    st_uid:        u32;
    st_gid:        u32;
    st_rdev:       i32;
    st_atime:      i64;
    st_atime_nsec: i64;
    st_mtime:      i64;
    st_mtime_nsec: i64;
    st_ctime:      i64;
    st_ctime_nsec: i64;
    st_birthtime:      i64;
    st_birthtime_nsec: i64;
    st_size:       i64;
    st_blocks:     i64;
    st_blksize:    i32;
    st_flags:      u32;
    st_gen:        u32;
    _reserved0:    i32;
    _reserved1:    i64;
    _reserved2:    i64;
}

rec timeval {
    tv_sec:  i64;
    tv_usec: i32;
    _pad:    i32;
}

pub rec timespec {
    tv_sec:  i64;
    tv_nsec: i64;
}

pub rec dirent64 {
    d_ino:    u64;
    d_seekoff: u64;
    d_reclen: u16;
    d_namlen: u16;
    d_type:   u8;
    d_name:   [1024]u8;
}

# path
pub val separator: u8 = shared.separator;

