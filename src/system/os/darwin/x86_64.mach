pub val O_DIRECTORY: i32 = c.O_DIRECTORY;

pub val AT_FDCWD:            i32 = c.AT_FDCWD;
pub val AT_SYMLINK_NOFOLLOW: i32 = c.AT_SYMLINK_NOFOLLOW;
pub val AT_REMOVEDIR:        i32 = c.AT_REMOVEDIR;

pub val S_IFMT:  u32 = c.S_IFMT;
