pub val EINTR_MAX_RETRIES: usize = c.EINTR_MAX_RETRIES;

# syscall wrappers (portable DSL — compiler adds BSD class offset on darwin x86_64)

pub fun syscall0(n: usize) i64 {
    var out: i64;
    asm { syscall out, n }
    ret out;
}

pub fun syscall1(n: usize, a0: usize) i64 {
    var out: i64;
    asm { syscall out, n, a0 }
    ret out;
}

pub fun syscall2(n: usize, a0: usize, a1: usize) i64 {
    var out: i64;
    asm { syscall out, n, a0, a1 }
    ret out;
}

pub fun syscall3(n: usize, a0: usize, a1: usize, a2: usize) i64 {
    var out: i64;
    asm { syscall out, n, a0, a1, a2 }
    ret out;
}

pub fun syscall4(n: usize, a0: usize, a1: usize, a2: usize, a3: usize) i64 {
    var out: i64;
    asm { syscall out, n, a0, a1, a2, a3 }
    ret out;
}

pub fun syscall5(n: usize, a0: usize, a1: usize, a2: usize, a3: usize, a4: usize) i64 {
    var out: i64;
    asm { syscall out, n, a0, a1, a2, a3, a4 }
    ret out;
}

pub fun syscall6(n: usize, a0: usize, a1: usize, a2: usize, a3: usize, a4: usize, a5: usize) i64 {
    var out: i64;
    asm { syscall out, n, a0, a1, a2, a3, a4, a5 }
    ret out;
}

# memory

pub fun allocate(size: usize) ptr {
    if (size == 0) {
        ret nil;
    }
    val res: i64 = syscall6(
        c.SYS_MMAP, 0, size,
        (c.PROT_READ | c.PROT_WRITE)::u32::usize,
        (c.MAP_PRIVATE | c.MAP_ANONYMOUS)::u32::usize,
        (-1)::isize::usize, 0
    );
    if (res < 0) {
        ret nil;
    }
    ret res::usize::ptr;
}

pub fun deallocate(p: ptr, size: usize) bool {
    if (p == nil || size == 0) {
        ret true;
    }
    ret syscall2(c.SYS_MUNMAP, p::usize, size) == 0;
}

pub fun reallocate(p: ptr, old_size: usize, new_size: usize) ptr {
    if (p == nil) {
        ret allocate(new_size);
    }
    if (new_size == 0) {
        deallocate(p, old_size);
        ret nil;
    }
    val new_p: ptr = allocate(new_size);
    if (new_p == nil) {
        ret nil;
    }
    var copy_size: usize = old_size;
    if (new_size < copy_size) {
        copy_size = new_size;
    }
    var i: usize = 0;
    for (i < copy_size) {
        @(new_p::usize + i)::*u8 = @(p::usize + i)::&u8;
        i = i + 1;
    }
    deallocate(p, old_size);
    ret new_p;
}

var _brk_base: usize = 0;
var _brk_end:  usize = 0;

pub fun heap_region_base() usize {
    if (_brk_base != 0) {
        ret _brk_end;
    }
    val res: i64 = syscall6(
        c.SYS_MMAP, 0, os_shared.HEAP_RESERVE,
        c.PROT_NONE::u32::usize,
        (c.MAP_PRIVATE | c.MAP_ANONYMOUS)::u32::usize,
        (-1)::isize::usize, 0
    );
    if (res < 0) {
        ret 0;
    }
    _brk_base = res::usize;
    _brk_end = _brk_base;
    ret _brk_end;
}

pub fun heap_region_extend(addr: usize) usize {
    if (_brk_base == 0) {
        heap_region_base();
        if (_brk_base == 0) {
            ret 0;
        }
    }
    if (addr <= _brk_end) {
        ret _brk_end;
    }
    if (addr > _brk_base + os_shared.HEAP_RESERVE) {
        ret _brk_end;
    }
    val size: usize = addr - _brk_end;
    val res: i64 = syscall3(
        c.SYS_MPROTECT, _brk_end,
        size, (c.PROT_READ | c.PROT_WRITE)::u32::usize
    );
    if (res < 0) {
        ret _brk_end;
    }
    _brk_end = addr;
    ret _brk_end;
}

pub fun protect(p: ptr, size: usize, prot: u32) bool {
    ret syscall3(c.SYS_MPROTECT, p::usize, size, prot::usize) == 0;
}

pub fun lock(p: ptr, size: usize) bool {
    ret syscall2(c.SYS_MLOCK, p::usize, size) == 0;
}

pub fun unlock(p: ptr, size: usize) bool {
    ret syscall2(c.SYS_MUNLOCK, p::usize, size) == 0;
}

pub fun advise(p: ptr, size: usize, advice: u32) bool {
    ret syscall3(c.SYS_MADVISE, p::usize, size, advice::usize) == 0;
}

pub fun page_size() usize {
    ret 4096;
}

pub fun map_file(fd: i32, offset: usize, size: usize, prot: u32) ptr {
    if (size == 0) {
        ret nil;
    }
    val res: i64 = syscall6(
        c.SYS_MMAP, 0, size,
        prot::usize, c.MAP_SHARED::u32::usize,
        fd::u32::usize, offset
    );
    if (res < 0) {
        ret nil;
    }
    ret res::usize::ptr;
}

pub fun sync_file(p: ptr, size: usize) bool {
    if (p == nil || size == 0) {
        ret true;
    }
    ret syscall3(c.SYS_MSYNC, p::usize, size, c.MS_SYNC::u32::usize) == 0;
}

# environment (set by runtime at program start)
pub var _envp: usize = 0;

# filesystem

pub fun read(fd: i32, buf: *u8, count: usize) i64 {
    var retries: usize = 0;
    for (retries < c.EINTR_MAX_RETRIES) {
        val res: i64 = syscall3(c.SYS_READ, fd::isize::usize, buf::usize, count);
        if (res != c.EINTR) { ret res; }
        retries = retries + 1;
    }
    ret c.EINTR;
}

pub fun write(fd: i32, buf: &u8, count: usize) i64 {
    var retries: usize = 0;
    for (retries < c.EINTR_MAX_RETRIES) {
        val res: i64 = syscall3(c.SYS_WRITE, fd::isize::usize, buf::usize, count);
        if (res != c.EINTR) { ret res; }
        retries = retries + 1;
    }
    ret c.EINTR;
}

pub fun open(dirfd: i32, path: &u8, flags: i32, mode: i32) i64 {
    var retries: usize = 0;
    for (retries < c.EINTR_MAX_RETRIES) {
        val res: i64 = syscall4(c.SYS_OPENAT, dirfd::isize::usize, path::usize, flags::u32::usize, mode::u32::usize);
        if (res != c.EINTR) { ret res; }
        retries = retries + 1;
    }
    ret c.EINTR;
}

pub fun close(fd: i32) i64 {
    ret syscall1(c.SYS_CLOSE, fd::isize::usize);
}

pub fun stat(fd: i32, st: *stat_t) i64 {
    ret syscall2(c.SYS_FSTAT64, fd::isize::usize, st::usize);
}

pub fun stat_path(dirfd: i32, path: &u8, st: *stat_t, flags: i32) i64 {
    ret syscall4(c.SYS_FSTATAT64, dirfd::isize::usize, path::usize, st::usize, flags::u32::usize);
}

pub fun unlink(dirfd: i32, path: &u8, flags: i32) i64 {
    ret syscall3(c.SYS_UNLINKAT, dirfd::isize::usize, path::usize, flags::u32::usize);
}

pub fun rename(olddir: i32, oldpath: &u8, newdir: i32, newpath: &u8) i64 {
    ret syscall4(c.SYS_RENAMEAT, olddir::isize::usize, oldpath::usize, newdir::isize::usize, newpath::usize);
}

pub fun make_dir(dirfd: i32, path: &u8, mode: i32) i64 {
    ret syscall3(c.SYS_MKDIRAT, dirfd::isize::usize, path::usize, mode::u32::usize);
}

pub fun read_dir(fd: i32, dirp: *dirent64, count: usize) i64 {
    var basep: i64 = 0;
    ret syscall4(c.SYS_GETDIRENTRIES64, fd::isize::usize, dirp::usize, count, ?basep::usize);
}

pub fun access(dirfd: i32, path: &u8, mode: i32, flags: i32) i64 {
    ret syscall4(c.SYS_FACCESSAT, dirfd::isize::usize, path::usize, mode::u32::usize, flags::u32::usize);
}

pub fun seek(fd: i32, offset: i64, whence: i32) i64 {
    ret syscall3(c.SYS_LSEEK, fd::isize::usize, offset::isize::usize, whence::u32::usize);
}

# process

pub fun terminate(code: i64) {
    syscall1(c.SYS_EXIT, code::usize);
    asm {
        x86_64 {
            hlt
        }
    }
}

pub fun abort() {
    val pid: i64 = syscall0(c.SYS_GETPID);
    syscall2(c.SYS_KILL, pid::usize, c.SIGABRT::usize);
    terminate(255);
}

pub fun fork() i64 {
    ret syscall0(c.SYS_FORK);
}

pub fun vfork() i64 {
    ret syscall0(c.SYS_VFORK);
}

pub fun exec(pathname: &u8, argv: &&u8, envp: &&u8) i64 {
    ret syscall3(c.SYS_EXECVE, pathname::usize, argv::usize, envp::usize);
}

pub fun wait(pid: i64, wstatus: *i32, options: i32, rusage: *u8) i64 {
    var retries: usize = 0;
    for (retries < c.EINTR_MAX_RETRIES) {
        val res: i64 = syscall4(c.SYS_WAIT4, pid::usize, wstatus::usize, options::usize, rusage::usize);
        if (res != c.EINTR) { ret res; }
        retries = retries + 1;
    }
    ret c.EINTR;
}

pub fun wait_pid(pid: i64, wstatus: *i32, options: i32) i64 {
    ret wait(pid, wstatus, options, nil);
}

pub fun has_exited(status: i32) bool {
    ret (status & 0x7f) == 0;
}

pub fun exit_code(status: i32) i32 {
    ret (status >> 8) & 0xff;
}

pub fun was_signaled(status: i32) bool {
    val sig: i32 = status & 0x7f;
    ret sig != 0 && sig != 0x7f;
}

pub fun term_signal(status: i32) i32 {
    ret status & 0x7f;
}

pub fun was_stopped(status: i32) bool {
    ret (status & 0xff) == 0x7f;
}

pub fun stop_signal(status: i32) i32 {
    ret (status >> 8) & 0xff;
}

pub fun was_continued(status: i32) bool {
    ret status == 0xffff;
}

# spawn: create a child process running the given program.
# ---
# pathname: path to executable
# argv:     null-terminated argument array
# envp:     null-terminated environment array
# ret:      child PID on success, or negative errno
pub fun spawn(pathname: &u8, argv: &&u8, envp: &&u8) i64 {
    val pid: i64 = fork();
    if (pid < 0) {
        ret pid;
    }
    if (pid == 0) {
        exec(pathname, argv, envp);
        syscall1(c.SYS_EXIT, 127);
    }
    ret pid;
}

# getpid: return the current process ID.
# ---
# ret: process ID
pub fun getpid() i64 {
    ret syscall0(c.SYS_GETPID);
}

# pipe: create a unidirectional pipe.
#
# darwin pipe() syscall returns two fds in eax/edx. the syscall DSL only
# captures eax, so this uses raw asm with a global to capture both.
# ---
# fds: pointer to two i32s; fds[0] = read end, fds[1] = write end
# ret: 0 on success, or negative errno
pub fun pipe(fds: *i32) i64 {
    var result: i64 = 0;
    asm {
        x86_64 {
            mov r8, rdi
            mov eax, 0x200002A
            syscall
            jc 1f
            mov [r8], eax
            mov [r8+4], edx
            xor eax, eax
            jmp 2f
        1:
            neg rax
        2:
            mov [result], rax
        }
    }
    ret result;
}

# sleep: suspend execution for the given number of nanoseconds.
#
# darwin has no nanosleep syscall; uses select with a timeval timeout.
# ---
# nsec: nanoseconds to sleep
pub fun sleep(nsec: i64) {
    if (nsec <= 0) { ret; }
    var tv: timeval;
    tv.tv_sec = nsec / 1000000000;
    tv.tv_usec = ((nsec % 1000000000) / 1000)::i32;
    syscall5(c.SYS_SELECT, 0, 0, 0, 0, ?tv::usize);
}

# getcwd: get the current working directory.
# ---
# buf:  destination buffer
# size: buffer capacity in bytes
# ret:  length of path on success, or negative errno
pub fun getcwd(buf: *u8, size: usize) i64 {
    ret syscall2(c.SYS___GETCWD, buf::usize, size);
}

fun str_len(s: &u8) usize {
    var i: usize = 0;
    for (s[i] != 0) {
        i = i + 1;
    }
    ret i;
}

fun str_eq_n(a: &u8, b: &u8, n: usize) bool {
    var i: usize = 0;
    for (i < n) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret true;
}

# getenv: look up an environment variable by name.
# ---
# name: null-terminated variable name
# buf:  destination buffer for the value
# cap:  buffer capacity in bytes
# ret:  length of value on success, or ENOENT if not found
pub fun getenv(name: &u8, buf: *u8, cap: usize) i64 {
    if (_envp == 0) { ret c.ENOENT; }
    val envp: &&u8 = _envp::&&u8;
    val name_len: usize = str_len(name);
    var i: usize = 0;
    for (envp[i]::usize != 0) {
        val entry: &u8 = envp[i];
        if (str_len(entry) > name_len && entry[name_len] == '='::u8 && str_eq_n(entry, name, name_len)) {
            if (cap == 0) { ret 0; }
            val val_start: usize = name_len + 1;
            var j: usize = 0;
            for (entry[val_start + j] != 0 && j < cap - 1) {
                buf[j] = entry[val_start + j];
                j = j + 1;
            }
            if (j < cap) {
                buf[j] = 0;
            }
            ret j::i64;
        }
        i = i + 1;
    }
    ret c.ENOENT;
}

# threads

var thread_registered: i64 = 0;

# called by the kernel for each new thread created via bsdthread_create.
# the kernel passes the func and arg values from the bsdthread_create call.
fun thread_start(self: usize, kport: usize, func: usize, arg: usize, stacksize: usize, pflags: usize) {
    val ctx: &usize = arg::&usize;
    val done_addr: usize = ctx[0];
    val stack_base: usize = ctx[1];
    val stack_size: usize = ctx[2];
    val fn_ptr: fun() = func::fun();
    fn_ptr();
    val done: *i64 = done_addr::*i64;
    @done = 1;
    syscall3(c.SYS_ULOCK_WAKE, c.UL_COMPARE_AND_WAIT64, done_addr, 0);
    syscall4(c.SYS_BSDTHREAD_TERMINATE, stack_base, stack_size, kport, 0);
}

# workqueue thread callback (unused, required by bsdthread_register).
fun thread_wq_start(self: usize, kport: usize, saddr: usize, arg: usize, cnt: usize, flags: usize) {
    syscall4(c.SYS_BSDTHREAD_TERMINATE, 0, 0, 0, 0);
}

fun ensure_thread_registered() {
    if (thread_registered != 0) { ret; }
    val start: fun(usize, usize, usize, usize, usize, usize) = thread_start;
    val wq: fun(usize, usize, usize, usize, usize, usize) = thread_wq_start;
    syscall6(c.SYS_BSDTHREAD_REGISTER, start::usize, wq::usize, 64, 0, 0, 0);
    thread_registered = 1;
}

# thread_spawn: create a new thread via bsdthread_create.
#
# registers the thread start callback on first call, then creates a
# thread that calls f. the kernel passes f and done_ptr through to
# the registered callback, which calls f, sets *done_ptr to 1, wakes
# waiters, and terminates the thread.
# ---
# f:          function to execute in the new thread
# done_ptr:   pointer to a completion flag (set to 1 when thread exits)
# stack_base: base address of the pre-allocated stack region
# stack_size: size of the stack in bytes
# ret:        thread ID on success, or negative errno on failure
pub fun thread_spawn(f: fun(), done_ptr: *i64, stack_base: usize, stack_size: usize) i64 {
    ensure_thread_registered();
    val ctx: *usize = stack_base::*usize;
    ctx[0] = done_ptr::usize;
    ctx[1] = stack_base;
    ctx[2] = stack_size;
    val stack_top: usize = stack_base + stack_size;
    ret syscall5(c.SYS_BSDTHREAD_CREATE, f::usize, ctx::usize, stack_top, 0, 0);
}

# thread_wait: block until the value at addr changes from expected.
#
# wraps __ulock_wait with UL_COMPARE_AND_WAIT64. returns immediately
# if *addr does not equal expected. spurious wakeups are possible.
# ---
# addr:     pointer to the futex word
# expected: value to compare against
# ret:      0 on wake, or negative errno
pub fun thread_wait(addr: *i64, expected: i64) i64 {
    ret syscall4(c.SYS_ULOCK_WAIT, c.UL_COMPARE_AND_WAIT64, addr::usize, expected::usize, 0);
}

# thread_wake: wake one thread blocked on a ulock wait at addr.
# ---
# addr: pointer to the futex word
# ret:  number of threads woken, or negative errno
pub fun thread_wake(addr: *i64) i64 {
    ret syscall3(c.SYS_ULOCK_WAKE, c.UL_COMPARE_AND_WAIT64, addr::usize, 0);
}

# sockets

pub val AF_INET:      i32 = c.AF_INET;
pub val SOCK_STREAM:  i32 = c.SOCK_STREAM;
pub val SOCK_DGRAM:   i32 = c.SOCK_DGRAM;
pub val SOL_SOCKET:   i32 = c.SOL_SOCKET;
pub val SO_REUSEADDR: i32 = c.SO_REUSEADDR;
pub val SHUT_RD:      i32 = c.SHUT_RD;
pub val SHUT_WR:      i32 = c.SHUT_WR;
pub val SHUT_RDWR:    i32 = c.SHUT_RDWR;

pub val SOCKADDR_IN_SIZE: usize = 16;

pub fun sock_addr_init(sa: *u8, port: u16, addr: &u8) {
    var i: usize = 0;
    for (i < SOCKADDR_IN_SIZE) { sa[i] = 0; i = i + 1; }
    sa[0] = SOCKADDR_IN_SIZE::u8;
    sa[1] = AF_INET::u8;
    sa[2] = (port >> 8)::u8;
    sa[3] = (port & 255)::u8;
    sa[4] = addr[0];
    sa[5] = addr[1];
    sa[6] = addr[2];
    sa[7] = addr[3];
}

pub fun sock_addr_read(sa: &u8, port: *u16, addr: *u8) {
    @port = (sa[2]::u16 << 8) | sa[3]::u16;
    addr[0] = sa[4];
    addr[1] = sa[5];
    addr[2] = sa[6];
    addr[3] = sa[7];
}

pub fun sock_send(fd: i32, buf: &u8, len: usize) i64 {
    ret write(fd, buf, len);
}

pub fun sock_recv(fd: i32, buf: *u8, len: usize) i64 {
    ret read(fd, buf, len);
}

pub fun sock_close(fd: i32) i64 {
    ret close(fd);
}

pub fun sock_create(domain: i32, typ: i32, protocol: i32) i64 {
    ret syscall3(c.SYS_SOCKET, domain::u32::usize, typ::u32::usize, protocol::u32::usize);
}

pub fun sock_bind(fd: i32, addr: *u8, addrlen: usize) i64 {
    ret syscall3(c.SYS_BIND, fd::isize::usize, addr::usize, addrlen);
}

pub fun sock_listen(fd: i32, backlog: i32) i64 {
    ret syscall2(c.SYS_LISTEN, fd::isize::usize, backlog::u32::usize);
}

pub fun sock_accept(fd: i32, addr: *u8, addrlen: *u32) i64 {
    ret syscall3(c.SYS_ACCEPT, fd::isize::usize, addr::usize, addrlen::usize);
}

pub fun sock_connect(fd: i32, addr: *u8, addrlen: usize) i64 {
    ret syscall3(c.SYS_CONNECT, fd::isize::usize, addr::usize, addrlen);
}

pub fun sock_sendto(fd: i32, buf: &u8, len: usize, flags: i32, addr: *u8, addrlen: usize) i64 {
    ret syscall6(c.SYS_SENDTO, fd::isize::usize, buf::usize, len, flags::u32::usize, addr::usize, addrlen);
}

pub fun sock_recvfrom(fd: i32, buf: *u8, len: usize, flags: i32, addr: *u8, addrlen: *u32) i64 {
    ret syscall6(c.SYS_RECVFROM, fd::isize::usize, buf::usize, len, flags::u32::usize, addr::usize, addrlen::usize);
}

pub fun sock_shutdown(fd: i32, how: i32) i64 {
    ret syscall2(c.SYS_SHUTDOWN, fd::isize::usize, how::u32::usize);
}

pub fun sock_setopt(fd: i32, level: i32, opt: i32, value: *u8, vallen: usize) i64 {
    ret syscall5(c.SYS_SETSOCKOPT, fd::isize::usize, level::u32::usize, opt::u32::usize, value::usize, vallen);
}

# dns

pub val DNS_HOSTS_PATH: str = "/etc/hosts";

# dns_nameserver: read the first nameserver from /etc/resolv.conf.
# ---
# ns:  pointer to 4 bytes to fill with the IPv4 address
# ret: true if a nameserver was found
pub fun dns_nameserver(ns: *u8) bool {
    val fd: i64 = open(AT_FDCWD, "/etc/resolv.conf", O_RDONLY, 0);
    if (fd < 0) { ret false; }

    var buf: [2048]u8;
    val n: i64 = read(fd::i32, ?buf[0], 2048);
    close(fd::i32);
    if (n <= 0) { ret false; }

    val len: usize = n::usize;
    var pos: usize = 0;

    for (pos < len) {
        for (pos < len && (buf[pos] == 32 || buf[pos] == 9)) { pos = pos + 1; }

        if (pos + 10 < len && dns_prefix_match(?buf[pos], "nameserver", 10)) {
            pos = pos + 10;
            for (pos < len && (buf[pos] == 32 || buf[pos] == 9)) { pos = pos + 1; }
            var start: usize = pos;
            for (pos < len && buf[pos] != 32 && buf[pos] != 9 && buf[pos] != 10) {
                pos = pos + 1;
            }
            if (pos > start && dns_parse_ns_addr(?buf[start], pos - start, ns)) {
                ret true;
            }
        }

        for (pos < len && buf[pos] != 10) { pos = pos + 1; }
        if (pos < len) { pos = pos + 1; }
    }

    ret false;
}

fun dns_prefix_match(a: &u8, b: &u8, len: usize) bool {
    var i: usize = 0;
    for (i < len) {
        if (a[i] != b[i]) { ret false; }
        i = i + 1;
    }
    ret true;
}

fun dns_parse_ns_addr(buf: &u8, len: usize, addr: *u8) bool {
    var octet: u16 = 0;
    var idx: usize = 0;
    var i: usize = 0;
    for (i < len) {
        if (buf[i] == 46) {
            if (octet > 255 || idx >= 4) { ret false; }
            addr[idx] = octet::u8;
            idx = idx + 1;
            octet = 0;
        } or (buf[i] >= 48 && buf[i] <= 57) {
            octet = octet * 10 + (buf[i] - 48)::u16;
        } or {
            ret false;
        }
        i = i + 1;
    }
    if (idx != 3 || octet > 255) { ret false; }
    addr[3] = octet::u8;
    ret true;
}

# random

# random_fill: fill a buffer with cryptographic random bytes via getentropy.
# ---
# buf:  destination buffer
# len:  number of bytes to fill
# ret:  true on success
pub fun random_fill(buf: *u8, len: usize) bool {
    if (len == 0) { ret true; }
    var filled: usize = 0;
    for (filled < len) {
        var chunk: usize = len - filled;
        if (chunk > 256) { chunk = 256; }
        val dst: usize = buf::usize + filled;
        val res: i64 = syscall2(c.SYS_GETENTROPY, dst, chunk);
        if (res < 0) { ret false; }
        filled = filled + chunk;
    }
    ret true;
}

# time
# TODO: CLOCK_MONOTONIC not actually monotonic on darwin — uses gettimeofday.
# needs mach_absolute_time() via commpage for true monotonic time.

pub fun clock_gettime(clock_id: i32, ts: *timespec) i64 {
    var tv: timeval;
    val res: i64 = syscall2(c.SYS_GETTIMEOFDAY, ?tv::usize, 0);
    if (res < 0) {
        ret res;
    }
    ts.tv_sec = tv.tv_sec;
    ts.tv_nsec = tv.tv_usec::i64 * 1000;
    ret 0;
}

# errno

pub fun error_message(code: i64) str {
    if (code == c.EPERM) { ret "operation not permitted"; }
    or (code == c.ENOENT) { ret "no such file or directory"; }
    or (code == c.ESRCH) { ret "no such process"; }
    or (code == c.EINTR) { ret "interrupted system call"; }
    or (code == c.EIO) { ret "input/output error"; }
    or (code == c.ENXIO) { ret "no such device or address"; }
    or (code == c.E2BIG) { ret "argument list too long"; }
    or (code == c.EBADF) { ret "bad file descriptor"; }
    or (code == c.ECHILD) { ret "no child processes"; }
    or (code == c.EAGAIN) { ret "resource temporarily unavailable"; }
    or (code == c.ENOMEM) { ret "out of memory"; }
    or (code == c.EACCES) { ret "permission denied"; }
    or (code == c.EFAULT) { ret "bad address"; }
    or (code == c.EBUSY) { ret "device or resource busy"; }
    or (code == c.EEXIST) { ret "file exists"; }
    or (code == c.ENODEV) { ret "no such device"; }
    or (code == c.ENOTDIR) { ret "not a directory"; }
    or (code == c.EISDIR) { ret "is a directory"; }
    or (code == c.EINVAL) { ret "invalid argument"; }
    or (code == c.ENFILE) { ret "too many open files in system"; }
    or (code == c.EMFILE) { ret "too many open files"; }
    or (code == c.ETXTBSY) { ret "text file busy"; }
    or (code == c.ENOSPC) { ret "no space left on device"; }
    or (code == c.EROFS) { ret "read-only file system"; }
    or (code == c.EPIPE) { ret "broken pipe"; }
    or (code == c.ENOTEMPTY) { ret "directory not empty"; }
    or (code == c.ENOTSUP) { ret "operation not supported"; }
    or { ret "unknown error"; }
}
