# HANDLE-to-fd mapping table

val MAX_FDS: usize = 256;
var _handles: [256]isize;
var _find_handles: [256]isize;
var _initialized: bool = false;

fun init_fds() {
    if (_initialized) {
        ret;
    }
    var i: usize = 0;
    for (i < MAX_FDS) {
        _handles[i] = c.INVALID_HANDLE_VALUE;
        _find_handles[i] = c.INVALID_HANDLE_VALUE;
        i = i + 1;
    }
    _handles[0] = GetStdHandle(c.STD_INPUT_HANDLE);
    _handles[1] = GetStdHandle(c.STD_OUTPUT_HANDLE);
    _handles[2] = GetStdHandle(c.STD_ERROR_HANDLE);
    _initialized = true;
}

fun alloc_fd(h: isize) i32 {
    init_fds();
    var fd: usize = 3;
    for (fd < MAX_FDS) {
        if (_handles[fd] == c.INVALID_HANDLE_VALUE) {
            _handles[fd] = h;
            ret fd::i32;
        }
        fd = fd + 1;
    }
    ret -1;
}

fun get_handle(fd: i32) isize {
    init_fds();
    if (fd < 0 || fd::usize >= MAX_FDS) {
        ret c.INVALID_HANDLE_VALUE;
    }
    ret _handles[fd::usize];
}

fun free_fd(fd: i32) {
    if (fd >= 0 && fd::usize < MAX_FDS) {
        if (_find_handles[fd::usize] != c.INVALID_HANDLE_VALUE) {
            FindClose(_find_handles[fd::usize]);
            _find_handles[fd::usize] = c.INVALID_HANDLE_VALUE;
        }
        _handles[fd::usize] = c.INVALID_HANDLE_VALUE;
    }
}

# child process tracking table

val MAX_PROCS: usize = 64;
var _proc_handles: [64]isize;
var _proc_pids: [64]u32;
var _procs_init: u8 = 0;

fun init_procs() {
    if (_procs_init != 0) { ret; }
    var i: usize = 0;
    for (i < MAX_PROCS) {
        _proc_handles[i] = c.INVALID_HANDLE_VALUE;
        _proc_pids[i] = 0;
        i = i + 1;
    }
    _procs_init = 1;
}

fun alloc_proc(pid: u32, handle: isize) bool {
    init_procs();
    var i: usize = 0;
    for (i < MAX_PROCS) {
        if (_proc_handles[i] == c.INVALID_HANDLE_VALUE) {
            _proc_handles[i] = handle;
            _proc_pids[i] = pid;
            ret true;
        }
        i = i + 1;
    }
    ret false;
}

fun get_proc_handle(pid: u32) isize {
    init_procs();
    var i: usize = 0;
    for (i < MAX_PROCS) {
        if (_proc_pids[i] == pid && _proc_handles[i] != c.INVALID_HANDLE_VALUE) {
            ret _proc_handles[i];
        }
        i = i + 1;
    }
    ret c.INVALID_HANDLE_VALUE;
}

fun free_proc(pid: u32) {
    var i: usize = 0;
    for (i < MAX_PROCS) {
        if (_proc_pids[i] == pid && _proc_handles[i] != c.INVALID_HANDLE_VALUE) {
            _proc_handles[i] = c.INVALID_HANDLE_VALUE;
            _proc_pids[i] = 0;
            ret;
        }
        i = i + 1;
    }
}

fun count_procs() usize {
    init_procs();
    var n: usize = 0;
    var i: usize = 0;
    for (i < MAX_PROCS) {
        if (_proc_handles[i] != c.INVALID_HANDLE_VALUE) {
            n = n + 1;
        }
        i = i + 1;
    }
    ret n;
}

# Win32 error → negated POSIX errno
fun last_error() i64 {
    val err: u32 = GetLastError();
    if (err == c.ERROR_FILE_NOT_FOUND || err == c.ERROR_PATH_NOT_FOUND) { ret c.ENOENT; }
    or (err == c.ERROR_ACCESS_DENIED) { ret c.EACCES; }
    or (err == c.ERROR_ALREADY_EXISTS || err == c.ERROR_FILE_EXISTS) { ret c.EEXIST; }
    or (err == c.ERROR_INVALID_HANDLE || err == c.ERROR_INVALID_PARAMETER) { ret c.EINVAL; }
    or (err == c.ERROR_NOT_ENOUGH_MEMORY || err == c.ERROR_OUTOFMEMORY) { ret c.ENOMEM; }
    or (err == c.ERROR_DIR_NOT_EMPTY) { ret c.ENOTEMPTY; }
    or (err == c.ERROR_DISK_FULL || err == c.ERROR_HANDLE_DISK_FULL) { ret c.ENOSPC; }
    or (err == c.ERROR_BROKEN_PIPE) { ret c.EPIPE; }
    or (err == c.ERROR_DIRECTORY) { ret c.ENOTDIR; }
    or (err == c.ERROR_TOO_MANY_OPEN_FILES) { ret c.EMFILE; }
    or (err == c.ERROR_BUSY) { ret c.EBUSY; }
    or (err == c.ERROR_WRITE_PROTECT) { ret c.EROFS; }
    or (err == c.ERROR_NOT_SUPPORTED) { ret c.ENOTSUP; }
    or { ret c.EIO; }
}

# FILETIME → unix seconds + nanoseconds
fun filetime_to_unix(ft: FILETIME, sec: *i64, nsec: *i64) {
    val ticks: i64 = ft.dwLowDateTime::i64 | (ft.dwHighDateTime::i64 << 32);
    val unix_ticks: i64 = ticks - c.FILETIME_UNIX_EPOCH;
    @sec = unix_ticks / 10000000;
    @nsec = (unix_ticks % 10000000) * 100;
}

# build a command line string from a null-terminated argv array.
# escapes per the CommandLineToArgvW convention:
# ---
# argv: null-terminated array of null-terminated strings
# buf:  destination buffer
# cap:  size of buf in bytes
fun build_cmdline(argv: &&u8, buf: *u8, cap: usize) {
    var off: usize = 0;
    var i: usize = 0;
    for (argv[i]::usize != 0 && off < cap - 1) {
        if (i > 0 && off < cap - 1) {
            buf[off] = 32;
            off = off + 1;
        }
        val arg: &u8 = argv[i];
        var needs_quote: u8 = 0;
        var j: usize = 0;
        for (arg[j] != 0) {
            if (arg[j] == 32 || arg[j] == 9 || arg[j] == 34) {
                needs_quote = 1;
            }
            j = j + 1;
        }
        if (needs_quote != 0 && off < cap - 1) {
            buf[off] = 34;
            off = off + 1;
        }
        j = 0;
        for (arg[j] != 0 && off < cap - 1) {
            if (needs_quote != 0 && arg[j] == 92) {
                var nbs: usize = 0;
                for (arg[j + nbs] == 92) {
                    nbs = nbs + 1;
                }
                if (arg[j + nbs] == 34 || arg[j + nbs] == 0) {
                    var k: usize = 0;
                    for (k < nbs * 2 && off < cap - 1) {
                        buf[off] = 92;
                        off = off + 1;
                        k = k + 1;
                    }
                } or {
                    var k: usize = 0;
                    for (k < nbs && off < cap - 1) {
                        buf[off] = 92;
                        off = off + 1;
                        k = k + 1;
                    }
                }
                j = j + nbs;
            } or (needs_quote != 0 && arg[j] == 34) {
                if (off < cap - 1) {
                    buf[off] = 92;
                    off = off + 1;
                }
                if (off < cap - 1) {
                    buf[off] = 34;
                    off = off + 1;
                }
                j = j + 1;
            } or {
                buf[off] = arg[j];
                off = off + 1;
                j = j + 1;
            }
        }
        if (needs_quote != 0 && off < cap - 1) {
            buf[off] = 34;
            off = off + 1;
        }
        i = i + 1;
    }
    if (off < cap) {
        buf[off] = 0;
    }
}

# POSIX prot flags → Win32 page protection
fun prot_to_win32(prot: u32) u32 {
    if (prot == 0) { ret c.PAGE_NOACCESS; }
    val r: bool = (prot & 1) != 0;
    val w: bool = (prot & 2) != 0;
    val x: bool = (prot & 4) != 0;
    if (x && w) { ret c.PAGE_EXECUTE_READWRITE; }
    or (x && r) { ret c.PAGE_EXECUTE_READ; }
    or (x) { ret c.PAGE_EXECUTE; }
    or (w) { ret c.PAGE_READWRITE; }
    or (r) { ret c.PAGE_READONLY; }
    or { ret c.PAGE_NOACCESS; }
}

# memory

pub fun allocate(size: usize) ptr {
    if (size == 0) {
        ret nil;
    }
    ret VirtualAlloc(nil, size, c.MEM_COMMIT | c.MEM_RESERVE, c.PAGE_READWRITE);
}

pub fun deallocate(p: ptr, size: usize) bool {
    if (p == nil || size == 0) {
        ret true;
    }
    ret VirtualFree(p, 0, c.MEM_RELEASE) != 0;
}

pub fun reallocate(p: ptr, old_size: usize, new_size: usize) ptr {
    if (p == nil) {
        ret allocate(new_size);
    }
    if (new_size == 0) {
        deallocate(p, old_size);
        ret nil;
    }
    val new_p: ptr = allocate(new_size);
    if (new_p == nil) {
        ret nil;
    }
    var copy_size: usize = old_size;
    if (new_size < copy_size) {
        copy_size = new_size;
    }
    var i: usize = 0;
    for (i < copy_size) {
        @(new_p::usize + i)::*u8 = @(p::usize + i)::&u8;
        i = i + 1;
    }
    deallocate(p, old_size);
    ret new_p;
}

# windows heap simulation: reserve large region, commit on extend
var _brk_base: usize = 0;
var _brk_end:  usize = 0;

pub fun heap_region_base() usize {
    if (_brk_base != 0) {
        ret _brk_end;
    }
    val p: ptr = VirtualAlloc(nil, os_shared.HEAP_RESERVE, c.MEM_RESERVE, c.PAGE_NOACCESS);
    if (p == nil) {
        ret 0;
    }
    _brk_base = p::usize;
    _brk_end = _brk_base;
    ret _brk_end;
}

pub fun heap_region_extend(addr: usize) usize {
    if (_brk_base == 0) {
        heap_region_base();
        if (_brk_base == 0) {
            ret 0;
        }
    }
    if (addr <= _brk_end) {
        ret _brk_end;
    }
    if (addr > _brk_base + os_shared.HEAP_RESERVE) {
        ret _brk_end;
    }
    val size: usize = addr - _brk_end;
    val p: ptr = VirtualAlloc(_brk_end::ptr, size, c.MEM_COMMIT, c.PAGE_READWRITE);
    if (p == nil) {
        ret _brk_end;
    }
    _brk_end = addr;
    ret _brk_end;
}

pub fun protect(p: ptr, size: usize, prot: u32) bool {
    var old_prot: u32 = 0;
    ret VirtualProtect(p, size, prot_to_win32(prot), ?old_prot) != 0;
}

pub fun lock(p: ptr, size: usize) bool {
    ret VirtualLock(p, size) != 0;
}

pub fun unlock(p: ptr, size: usize) bool {
    ret VirtualUnlock(p, size) != 0;
}

pub fun advise(p: ptr, size: usize, advice: u32) bool {
    ret true;
}

pub fun page_size() usize {
    ret 4096;
}

# stub: reads file into allocated memory; prot is ignored (always read-only).
# writes to the returned region are not persisted to disk.
pub fun map_file(fd: i32, offset: usize, size: usize, prot: u32) ptr {
    if (size == 0) {
        ret nil;
    }
    val h: isize = get_handle(fd);
    if (h == c.INVALID_HANDLE_VALUE) {
        ret nil;
    }
    val p: ptr = allocate(size);
    if (p == nil) {
        ret nil;
    }
    var new_pos: i64 = 0;
    SetFilePointerEx(h, offset::i64, ?new_pos, c.FILE_BEGIN);
    var bytes_read: u32 = 0;
    val ok: i32 = ReadFile(h, p::*u8, size::u32, ?bytes_read, nil);
    if (ok == 0) {
        deallocate(p, size);
        ret nil;
    }
    ret p;
}

# stub: no actual flush — writes to mapped memory are not persisted
pub fun sync_file(p: ptr, size: usize) bool {
    if (p == nil || size == 0) {
        ret true;
    }
    ret true;
}

# filesystem

pub fun read(fd: i32, buf: *u8, count: usize) i64 {
    val h: isize = get_handle(fd);
    if (h == c.INVALID_HANDLE_VALUE) {
        ret c.EBADF;
    }
    var bytes_read: u32 = 0;
    val ok: i32 = ReadFile(h, buf, count::u32, ?bytes_read, nil);
    if (ok == 0) {
        ret last_error();
    }
    ret bytes_read::i64;
}

pub fun write(fd: i32, buf: &u8, count: usize) i64 {
    val h: isize = get_handle(fd);
    if (h == c.INVALID_HANDLE_VALUE) {
        ret c.EBADF;
    }
    var bytes_written: u32 = 0;
    val ok: i32 = WriteFile(h, buf, count::u32, ?bytes_written, nil);
    if (ok == 0) {
        ret last_error();
    }
    ret bytes_written::i64;
}

pub fun open(dirfd: i32, path: &u8, flags: i32, mode: i32) i64 {
    if (dirfd != c.AT_FDCWD) {
        ret c.ENOTSUP;
    }
    var access: u32 = 0;
    var creation: u32 = c.OPEN_EXISTING;
    var attrs: u32 = c.FILE_ATTRIBUTE_NORMAL;

    val rw: i32 = flags & 3;
    if (rw == c.O_RDONLY) {
        access = c.GENERIC_READ;
    }
    or (rw == c.O_WRONLY) {
        access = c.GENERIC_WRITE;
    }
    or {
        access = c.GENERIC_READ | c.GENERIC_WRITE;
    }

    if ((flags & c.O_CREAT) != 0 && (flags & c.O_EXCL) != 0) {
        creation = c.CREATE_NEW;
    }
    or ((flags & c.O_CREAT) != 0 && (flags & c.O_TRUNC) != 0) {
        creation = c.CREATE_ALWAYS;
    }
    or ((flags & c.O_CREAT) != 0) {
        creation = c.OPEN_ALWAYS;
    }
    or ((flags & c.O_TRUNC) != 0) {
        creation = c.TRUNCATE_EXISTING;
    }

    if ((flags & c.O_DIRECTORY) != 0) {
        attrs = attrs | c.FILE_FLAG_BACKUP_SEMANTICS;
    }

    val h: isize = CreateFileA(path, access, c.FILE_SHARE_READ | c.FILE_SHARE_WRITE | c.FILE_SHARE_DELETE, nil, creation, attrs, 0);
    if (h == c.INVALID_HANDLE_VALUE) {
        ret last_error();
    }

    if ((flags & c.O_APPEND) != 0) {
        var new_pos: i64 = 0;
        SetFilePointerEx(h, 0, ?new_pos, c.FILE_END);
    }

    val fd: i32 = alloc_fd(h);
    if (fd < 0) {
        CloseHandle(h);
        ret c.EMFILE;
    }
    ret fd::i64;
}

pub fun close(fd: i32) i64 {
    val h: isize = get_handle(fd);
    if (h == c.INVALID_HANDLE_VALUE) {
        ret c.EBADF;
    }
    free_fd(fd);
    if (CloseHandle(h) == 0) {
        ret last_error();
    }
    ret 0;
}

pub fun stat(fd: i32, st: *stat_t) i64 {
    val h: isize = get_handle(fd);
    if (h == c.INVALID_HANDLE_VALUE) {
        ret c.EBADF;
    }
    var info: BY_HANDLE_FILE_INFORMATION;
    if (GetFileInformationByHandle(h, ?info::*u8) == 0) {
        ret last_error();
    }
    st.st_dev = info.dwVolumeSerialNumber::u64;
    st.st_ino = info.nFileIndexLow::u64 | (info.nFileIndexHigh::u64 << 32);
    st.st_nlink = info.nNumberOfLinks::u64;
    st.st_size = info.nFileSizeLow::i64 | (info.nFileSizeHigh::i64 << 32);
    st.st_blksize = 4096;
    st.st_blocks = (st.st_size + 511) / 512;
    st.st_uid = 0;
    st.st_gid = 0;
    st.st_rdev = 0;
    if ((info.dwFileAttributes & c.FILE_ATTRIBUTE_DIRECTORY) != 0) {
        st.st_mode = c.S_IFDIR | 0o755::u32;
    }
    or ((info.dwFileAttributes & c.FILE_ATTRIBUTE_REPARSE_POINT) != 0) {
        st.st_mode = c.S_IFLNK | 0o777::u32;
    }
    or {
        st.st_mode = c.S_IFREG | 0o644::u32;
    }
    if ((info.dwFileAttributes & c.FILE_ATTRIBUTE_READONLY) != 0) {
        st.st_mode = st.st_mode & (0o777777::u32 - 0o222::u32);
    }
    filetime_to_unix(info.ftLastAccessTime, ?st.st_atime, ?st.st_atime_nsec);
    filetime_to_unix(info.ftLastWriteTime, ?st.st_mtime, ?st.st_mtime_nsec);
    filetime_to_unix(info.ftCreationTime, ?st.st_ctime, ?st.st_ctime_nsec);
    ret 0;
}

# stub: dirfd is ignored — path must be absolute or relative to cwd
pub fun stat_path(dirfd: i32, path: &u8, st: *stat_t, flags: i32) i64 {
    val attr: u32 = GetFileAttributesA(path);
    if (attr == 0xFFFFFFFF) {
        ret last_error();
    }
    var open_flags: i32 = c.O_RDONLY;
    if ((attr & c.FILE_ATTRIBUTE_DIRECTORY) != 0) {
        open_flags = open_flags | c.O_DIRECTORY;
    }
    val fd_result: i64 = open(dirfd, path, open_flags, 0);
    if (fd_result < 0) {
        ret fd_result;
    }
    val fd: i32 = fd_result::i32;
    val r: i64 = stat(fd, st);
    close(fd);
    ret r;
}

# stub: dirfd is ignored — path must be absolute or relative to cwd
pub fun unlink(dirfd: i32, path: &u8, flags: i32) i64 {
    if ((flags & c.AT_REMOVEDIR) != 0) {
        if (RemoveDirectoryA(path) == 0) {
            ret last_error();
        }
        ret 0;
    }
    if (DeleteFileA(path) == 0) {
        ret last_error();
    }
    ret 0;
}

# stub: olddir/newdir are ignored — paths must be absolute or relative to cwd
pub fun rename(olddir: i32, oldpath: &u8, newdir: i32, newpath: &u8) i64 {
    if (MoveFileA(oldpath, newpath) == 0) {
        ret last_error();
    }
    ret 0;
}

pub fun make_dir(dirfd: i32, path: &u8, mode: i32) i64 {
    if (CreateDirectoryA(path, nil) == 0) {
        ret last_error();
    }
    ret 0;
}

pub fun read_dir(fd: i32, dirp: *dirent64, count: usize) i64 {
    if (fd < 0 || fd::usize >= MAX_FDS) {
        ret c.EBADF;
    }
    val h: isize = _handles[fd::usize];
    if (h == c.INVALID_HANDLE_VALUE) {
        ret c.EBADF;
    }
    val entry_size: usize = 280;
    if (count < entry_size) {
        ret c.EINVAL;
    }
    var data: WIN32_FIND_DATAA;
    var fh: isize = _find_handles[fd::usize];
    var found: i32 = 1;
    if (fh == c.INVALID_HANDLE_VALUE) {
        # first call: get directory path and start enumeration
        var path_buf: [260]u8;
        val path_len: u32 = GetFinalPathNameByHandleA(h, ?path_buf[0], 260, 0);
        if (path_len == 0 || path_len >= 257) {
            ret last_error();
        }
        # append \* for glob pattern
        path_buf[path_len] = '\\'::u8;
        path_buf[path_len + 1] = '*'::u8;
        path_buf[path_len + 2] = 0;
        fh = FindFirstFileA(?path_buf[0]::&u8, ?data::*u8);
        if (fh == c.INVALID_HANDLE_VALUE) {
            ret last_error();
        }
        _find_handles[fd::usize] = fh;
    }
    or {
        found = FindNextFileA(fh, ?data::*u8);
    }
    var written: usize = 0;
    var buf: *u8 = dirp::*u8;
    for (found != 0) {
        if (written + entry_size > count) {
            brk;
        }
        var entry: *dirent64 = (buf::usize + written)::*dirent64;
        entry.d_ino = 0;
        entry.d_off = (written + entry_size)::i64;
        entry.d_reclen = entry_size::u16;
        if ((data.dwFileAttributes & c.FILE_ATTRIBUTE_DIRECTORY) != 0) {
            entry.d_type = 4;
        }
        or {
            entry.d_type = 8;
        }
        # copy filename
        var i: usize = 0;
        for (i < 259 && data.cFileName[i] != 0) {
            entry.d_name[i] = data.cFileName[i];
            i = i + 1;
        }
        entry.d_name[i] = 0;
        written = written + entry_size;
        found = FindNextFileA(fh, ?data::*u8);
    }
    if (written == 0) {
        FindClose(fh);
        _find_handles[fd::usize] = c.INVALID_HANDLE_VALUE;
        ret 0;
    }
    ret written::i64;
}

pub fun access(dirfd: i32, path: &u8, mode: i32, flags: i32) i64 {
    val attr: u32 = GetFileAttributesA(path);
    if (attr == 0xFFFFFFFF) {
        ret last_error();
    }
    ret 0;
}

pub fun seek(fd: i32, offset: i64, whence: i32) i64 {
    val h: isize = get_handle(fd);
    if (h == c.INVALID_HANDLE_VALUE) {
        ret c.EBADF;
    }
    var method: u32 = c.FILE_BEGIN;
    if (whence == c.SEEK_CUR) {
        method = c.FILE_CURRENT;
    }
    or (whence == c.SEEK_END) {
        method = c.FILE_END;
    }
    var new_pos: i64 = 0;
    if (SetFilePointerEx(h, offset, ?new_pos, method) == 0) {
        ret last_error();
    }
    ret new_pos;
}

# process

pub fun terminate(code: i64) {
    ExitProcess(code::u32);
}

pub fun abort() {
    ExitProcess(255);
}

# spawn: create a child process running the given program.
#
# uses CreateProcess to launch the child. the process handle is tracked
# in the process table for wait/wait_pid. envp is ignored; the child
# inherits the parent's environment.
# ---
# pathname: path to executable
# argv:     null-terminated argument array
# envp:     null-terminated environment array (ignored on windows)
# ret:      child PID on success, or negative errno
pub fun spawn(pathname: &u8, argv: &&u8, envp: &&u8) i64 {
    var cmdline: [32768]u8;
    build_cmdline(argv, ?cmdline[0], 32768);

    var si: [104]u8;
    var k: usize = 0;
    for (k < 104) {
        si[k] = 0;
        k = k + 1;
    }
    si[0] = 104;

    var pi: PROCESS_INFORMATION;

    val ok: i32 = CreateProcessA(
        pathname, ?cmdline[0],
        nil, nil,
        1, 0,
        nil, nil,
        ?si[0], ?pi::*u8
    );
    if (ok == 0) {
        ret last_error();
    }

    CloseHandle(pi.hThread);
    if (!alloc_proc(pi.dwProcessId, pi.hProcess)) {
        CloseHandle(pi.hProcess);
        ret c.EAGAIN;
    }
    ret pi.dwProcessId::i64;
}

# getpid: return the current process ID.
# ---
# ret: process ID
pub fun getpid() i64 {
    ret GetCurrentProcessId()::i64;
}

# pipe: create a unidirectional pipe.
# ---
# fds: pointer to two i32s; fds[0] = read end, fds[1] = write end
# ret: 0 on success, or negative errno
pub fun pipe(fds: *i32) i64 {
    var read_h: isize = 0;
    var write_h: isize = 0;
    if (CreatePipe(?read_h, ?write_h, nil, 0) == 0) {
        ret last_error();
    }
    val rfd: i32 = alloc_fd(read_h);
    if (rfd < 0) {
        CloseHandle(read_h);
        CloseHandle(write_h);
        ret c.EMFILE;
    }
    val wfd: i32 = alloc_fd(write_h);
    if (wfd < 0) {
        free_fd(rfd);
        CloseHandle(read_h);
        CloseHandle(write_h);
        ret c.EMFILE;
    }
    fds[0] = rfd;
    fds[1] = wfd;
    ret 0;
}

# sleep: suspend execution for the given number of nanoseconds.
# ---
# nsec: nanoseconds to sleep
pub fun sleep(nsec: i64) {
    if (nsec <= 0) { ret; }
    val ms: u32 = (nsec / 1000000)::u32;
    SleepW(ms);
}

# getcwd: get the current working directory.
# ---
# buf:  destination buffer
# size: buffer capacity in bytes
# ret:  length of path on success, or negative errno
pub fun getcwd(buf: *u8, size: usize) i64 {
    val len: u32 = GetCurrentDirectoryA(size::u32, buf);
    if (len == 0) {
        ret last_error();
    }
    ret len::i64;
}

# getenv: look up an environment variable by name.
# ---
# name: null-terminated variable name
# buf:  destination buffer for the value
# cap:  buffer capacity in bytes
# ret:  length of value on success, or ENOENT if not found
pub fun getenv(name: &u8, buf: *u8, cap: usize) i64 {
    val len: u32 = GetEnvironmentVariableA(name, buf, cap::u32);
    if (len == 0) {
        val err: u32 = GetLastError();
        if (err == 203) {
            ret c.ENOENT;
        }
        ret c.EIO;
    }
    ret len::i64;
}

# wait: wait for a child process to change state.
#
# uses the process handle table to look up children by pid.
# pid == -1 waits for any child. WNOHANG uses a zero timeout.
pub fun wait(pid: i64, wstatus: *i32, options: i32, rusage: *u8) i64 {
    init_procs();

    if (pid > 0) {
        val h: isize = get_proc_handle(pid::u32);
        if (h == c.INVALID_HANDLE_VALUE) {
            ret c.ECHILD;
        }

        var timeout: u32 = c.INFINITE;
        if ((options & c.WNOHANG) != 0) {
            timeout = 0;
        }

        val result: u32 = WaitForSingleObject(h, timeout);
        if (result == c.WAIT_TIMEOUT) {
            ret 0;
        }
        if (result == c.WAIT_FAILED) {
            ret last_error();
        }

        var ec: u32 = 0;
        GetExitCodeProcess(h, ?ec);
        if (wstatus != nil) {
            @wstatus = (ec::i32 << 8);
        }
        CloseHandle(h);
        free_proc(pid::u32);
        ret pid;
    }

    if (pid == -1) {
        var wait_handles: [64]isize;
        var wait_pids: [64]u32;
        var n: usize = 0;
        var i: usize = 0;

        for (i < MAX_PROCS) {
            if (_proc_handles[i] != c.INVALID_HANDLE_VALUE) {
                wait_handles[n] = _proc_handles[i];
                wait_pids[n] = _proc_pids[i];
                n = n + 1;
            }
            i = i + 1;
        }

        if (n == 0) {
            ret c.ECHILD;
        }

        var timeout: u32 = c.INFINITE;
        if ((options & c.WNOHANG) != 0) {
            timeout = 0;
        }

        val result: u32 = WaitForMultipleObjects(n::u32, ?wait_handles[0]::ptr, 0, timeout);
        if (result == c.WAIT_TIMEOUT) {
            ret 0;
        }
        if (result == c.WAIT_FAILED) {
            ret last_error();
        }
        if (result >= n::u32) {
            ret c.EIO;
        }

        val idx: usize = result::usize;
        var ec: u32 = 0;
        GetExitCodeProcess(wait_handles[idx], ?ec);
        if (wstatus != nil) {
            @wstatus = (ec::i32 << 8);
        }
        val child_pid: u32 = wait_pids[idx];
        CloseHandle(wait_handles[idx]);
        free_proc(child_pid);
        ret child_pid::i64;
    }

    ret c.EINVAL;
}

pub fun wait_pid(pid: i64, wstatus: *i32, options: i32) i64 {
    ret wait(pid, wstatus, options, nil);
}

# wait status decoding (POSIX encoding: exit_code << 8 for normal exit)

pub fun has_exited(status: i32) bool {
    ret (status & 0x7f) == 0;
}

pub fun exit_code(status: i32) i32 {
    ret (status >> 8) & 0xff;
}

pub fun was_signaled(status: i32) bool {
    ret false;
}

pub fun term_signal(status: i32) i32 {
    ret 0;
}

pub fun was_stopped(status: i32) bool {
    ret false;
}

pub fun stop_signal(status: i32) i32 {
    ret 0;
}

# threads

# thread callback. receives the pre-allocated stack base as its parameter,
# where fn_addr and done_addr are stored at offsets 0 and 8.
fun thread_trampoline(arg: ptr) {
    val base: usize = arg::usize;
    val fn_addr: usize = @(base::*usize);
    val done_addr: usize = @((base + 8)::*usize);
    val fn_ptr: fun() = fn_addr::fun();
    fn_ptr();
    val done: *i64 = done_addr::*i64;
    @done = 1;
    WakeByAddressSingle(done::ptr);
}

# thread_spawn: create a new thread via CreateThread.
#
# stores fn and done_ptr at the base of the pre-allocated stack region,
# then passes that address as CreateThread's lpParameter. the trampoline
# reads both values from the parameter, so no globals are needed and
# multiple threads may be spawned concurrently.
# ---
# f:          function to execute in the new thread
# done_ptr:   pointer to a completion flag (set to 1 when thread exits)
# stack_base: base address of the pre-allocated stack region
# stack_size: size of the stack in bytes
# ret:        thread ID on success, or negative errno on failure
pub fun thread_spawn(f: fun(), done_ptr: *i64, stack_base: usize, stack_size: usize) i64 {
    @(stack_base::*usize) = f::usize;
    @((stack_base + 8)::*usize) = done_ptr::usize;
    var tid: u32 = 0;
    val tramp: fun(ptr) = thread_trampoline;
    val h: isize = CreateThread(nil, stack_size, tramp::usize, stack_base::ptr, 0, ?tid);
    if (h == 0) {
        ret last_error();
    }
    CloseHandle(h);
    ret tid::i64;
}

# thread_wait: block until the value at addr changes from expected.
#
# wraps WaitOnAddress for 64-bit compare-and-wait. returns immediately
# if *addr does not equal expected. spurious wakeups are possible.
# ---
# addr:     pointer to the futex word
# expected: value to compare against
# ret:      0 on wake, or negative errno
pub fun thread_wait(addr: *i64, expected: i64) i64 {
    var cmp: i64 = expected;
    val ok: i32 = WaitOnAddress(addr::ptr, ?cmp::ptr, 8, c.INFINITE);
    if (ok == 0) {
        ret last_error();
    }
    ret 0;
}

# thread_wake: wake one thread blocked on WaitOnAddress at addr.
# ---
# addr: pointer to the futex word
# ret:  0 (always succeeds)
pub fun thread_wake(addr: *i64) i64 {
    WakeByAddressSingle(addr::ptr);
    ret 0;
}

# sockets

pub val AF_INET:      i32 = c.AF_INET;
pub val SOCK_STREAM:  i32 = c.SOCK_STREAM;
pub val SOCK_DGRAM:   i32 = c.SOCK_DGRAM;
pub val SOL_SOCKET:   i32 = c.SOL_SOCKET;
pub val SO_REUSEADDR: i32 = c.SO_REUSEADDR;
pub val SHUT_RD:      i32 = c.SHUT_RD;
pub val SHUT_WR:      i32 = c.SHUT_WR;
pub val SHUT_RDWR:    i32 = c.SHUT_RDWR;

pub val SOCKADDR_IN_SIZE: usize = 16;

pub fun sock_addr_init(sa: *u8, port: u16, addr: &u8) {
    var i: usize = 0;
    for (i < SOCKADDR_IN_SIZE) { sa[i] = 0; i = i + 1; }
    sa[0] = AF_INET::u8;
    sa[1] = 0;
    sa[2] = (port >> 8)::u8;
    sa[3] = (port & 255)::u8;
    sa[4] = addr[0];
    sa[5] = addr[1];
    sa[6] = addr[2];
    sa[7] = addr[3];
}

pub fun sock_addr_read(sa: &u8, port: *u16, addr: *u8) {
    @port = (sa[2]::u16 << 8) | sa[3]::u16;
    addr[0] = sa[4];
    addr[1] = sa[5];
    addr[2] = sa[6];
    addr[3] = sa[7];
}

pub fun sock_send(fd: i32, buf: &u8, len: usize) i64 {
    if (!ensure_wsa()) { ret c.EIO; }
    val res: i32 = ws2_send(fd::usize, buf, len::i32, 0);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret res::i64;
}

pub fun sock_recv(fd: i32, buf: *u8, len: usize) i64 {
    if (!ensure_wsa()) { ret c.EIO; }
    val res: i32 = ws2_recv(fd::usize, buf, len::i32, 0);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret res::i64;
}

pub fun sock_close(fd: i32) {
    closesocket(fd::usize);
}

var wsa_initialized: i64 = 0;

fun ensure_wsa() bool {
    if (wsa_initialized != 0) { ret true; }
    var wsa_data: [408]u8;
    val res: i32 = WSAStartup(0x0202, ?wsa_data[0]);
    if (res != 0) { ret false; }
    wsa_initialized = 1;
    ret true;
}

pub fun sock_create(domain: i32, typ: i32, protocol: i32) i64 {
    if (!ensure_wsa()) { ret c.EIO; }
    val s: usize = ws2_socket(domain, typ, protocol);
    if (s == c.INVALID_SOCKET) { ret c.EIO; }
    ret s::i64;
}

pub fun sock_bind(fd: i32, addr: *u8, addrlen: usize) i64 {
    val res: i32 = ws2_bind(fd::usize, addr, addrlen::i32);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret 0;
}

pub fun sock_listen(fd: i32, backlog: i32) i64 {
    val res: i32 = ws2_listen(fd::usize, backlog);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret 0;
}

pub fun sock_accept(fd: i32, addr: *u8, addrlen: *u32) i64 {
    val s: usize = ws2_accept(fd::usize, addr, addrlen::*i32);
    if (s == c.INVALID_SOCKET) { ret c.EIO; }
    ret s::i64;
}

pub fun sock_connect(fd: i32, addr: *u8, addrlen: usize) i64 {
    val res: i32 = ws2_connect(fd::usize, addr, addrlen::i32);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret 0;
}

pub fun sock_sendto(fd: i32, buf: &u8, len: usize, flags: i32, addr: *u8, addrlen: usize) i64 {
    val res: i32 = ws2_sendto(fd::usize, buf, len::i32, flags, addr, addrlen::i32);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret res::i64;
}

pub fun sock_recvfrom(fd: i32, buf: *u8, len: usize, flags: i32, addr: *u8, addrlen: *u32) i64 {
    val res: i32 = ws2_recvfrom(fd::usize, buf, len::i32, flags, addr, addrlen::*i32);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret res::i64;
}

pub fun sock_shutdown(fd: i32, how: i32) i64 {
    val res: i32 = ws2_shutdown(fd::usize, how);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret 0;
}

pub fun sock_setopt(fd: i32, level: i32, opt: i32, value: *u8, vallen: usize) i64 {
    val res: i32 = ws2_setsockopt(fd::usize, level, opt, value, vallen::i32);
    if (res == c.SOCKET_ERROR) { ret c.EIO; }
    ret 0;
}

# dns

pub val DNS_HOSTS_PATH: str = "C:/Windows/System32/drivers/etc/hosts";

# dns_nameserver: get the primary DNS nameserver address.
#
# windows does not use /etc/resolv.conf. a real implementation would
# call GetAdaptersAddresses or read the registry. returns false until
# a Win32 implementation is added.
# ---
# ns:  pointer to 4 bytes to fill with the IPv4 address
# ret: true if a nameserver was found
pub fun dns_nameserver(ns: *u8) bool {
    ret false;
}

# random

# random_fill: fill a buffer with cryptographic random bytes via RtlGenRandom.
# ---
# buf:  destination buffer
# len:  number of bytes to fill
# ret:  true on success
pub fun random_fill(buf: *u8, len: usize) bool {
    if (len == 0) { ret true; }
    ret SystemFunction036(buf, len::u32) != 0;
}

# time

pub fun clock_gettime(clock_id: i32, ts: *timespec) i64 {
    if (clock_id == c.CLOCK_MONOTONIC) {
        var count: i64 = 0;
        var freq: i64 = 0;
        QueryPerformanceCounter(?count);
        QueryPerformanceFrequency(?freq);
        if (freq == 0) {
            ret c.EIO;
        }
        ts.tv_sec = count / freq;
        ts.tv_nsec = ((count % freq) * 1000000000) / freq;
        ret 0;
    }
    var ft: FILETIME;
    GetSystemTimeAsFileTime(?ft::*u8);
    filetime_to_unix(ft, ?ts.tv_sec, ?ts.tv_nsec);
    ret 0;
}

# errno

pub fun error_message(code: i64) str {
    if (code == c.EPERM) { ret "operation not permitted"; }
    or (code == c.ENOENT) { ret "no such file or directory"; }
    or (code == c.ESRCH) { ret "no such process"; }
    or (code == c.EINTR) { ret "interrupted system call"; }
    or (code == c.EIO) { ret "input/output error"; }
    or (code == c.ENXIO) { ret "no such device or address"; }
    or (code == c.E2BIG) { ret "argument list too long"; }
    or (code == c.EBADF) { ret "bad file descriptor"; }
    or (code == c.ECHILD) { ret "no child processes"; }
    or (code == c.EAGAIN) { ret "resource temporarily unavailable"; }
    or (code == c.ENOMEM) { ret "out of memory"; }
    or (code == c.EACCES) { ret "permission denied"; }
    or (code == c.EFAULT) { ret "bad address"; }
    or (code == c.EBUSY) { ret "device or resource busy"; }
    or (code == c.EEXIST) { ret "file exists"; }
    or (code == c.ENODEV) { ret "no such device"; }
    or (code == c.ENOTDIR) { ret "not a directory"; }
    or (code == c.EISDIR) { ret "is a directory"; }
    or (code == c.EINVAL) { ret "invalid argument"; }
    or (code == c.ENFILE) { ret "too many open files in system"; }
    or (code == c.EMFILE) { ret "too many open files"; }
    or (code == c.ETXTBSY) { ret "text file busy"; }
    or (code == c.ENOSPC) { ret "no space left on device"; }
    or (code == c.EROFS) { ret "read-only file system"; }
    or (code == c.EPIPE) { ret "broken pipe"; }
    or (code == c.ENOTEMPTY) { ret "directory not empty"; }
    or (code == c.ENOTSUP) { ret "operation not supported"; }
    or { ret "unknown error"; }
}
