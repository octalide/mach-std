# std.system.os.windows.x86_64: complete windows x86_64 OS interface.
#
# windows has no stable syscall interface. all OS interaction goes through
# kernel32.dll and ntdll.dll via ext fun declarations. a HANDLE-to-fd
# mapping table bridges the POSIX-style fd interface used by os.mach.

use std.types.size;
use std.types.bool;
use std.types.string;

use c:      std.system.os.windows.x86_64.constants;
use shared:    std.system.os.windows.shared;
use os_shared: std.system.os.shared;

$if ($mach.build.target.os.id != $mach.os.windows.id) {
    $error("std.system.os.windows.x86_64: requires windows target");
}

$if ($mach.build.target.arch.id != $mach.arch.x86_64.id) {
    $error("std.system.os.windows.x86_64: requires x86_64 target");
}

