test "buffer: round-trip i32" {
    var a: allocator.Allocator;
    page.make(?a);
    var wb: WriteBuf = wbuf_make(?a);

    wbuf_write[i32](?wb, -12345);

    var rb: ReadBuf = rbuf_make(wb.data, wb.len);
    val rr: Result[i32, str] = rbuf_read[i32](?rb);
