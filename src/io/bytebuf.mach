use std.types.bool;
use std.types.size;
use std.types.result;
use std.types.string;

use allocator: std.allocator;
use mem: std.memory;

# Growable byte buffer for binary serialization
pub rec WriteBuf {
    alloc: *allocator.Allocator;
    data:  *u8;
    len:   usize;
    cap:   usize;
}

# Create an empty WriteBuf using the provided allocator
# ---
# alloc: allocator to use for buffer memory
# ret:   a new empty WriteBuf
pub fun wbuf_init(alloc: *allocator.Allocator) WriteBuf {
    var buf: WriteBuf;
    buf.alloc = alloc;
    buf.data = nil;
    buf.len = 0;
    buf.cap = 0;
    ret buf;
}

# Free the buffer memory and reset fields
# ---
# buf: buffer to deinitialize
# ret: true if memory was freed successfully
pub fun wbuf_dnit(buf: *WriteBuf) bool {
    if (buf == nil) { ret true; }
    if (buf.cap == 0) {
        buf.data = nil;
        buf.len = 0;
        ret true;
    }

    val ok_free: bool = allocator.allocator_free[u8](buf.alloc, buf.data, buf.cap);
    if (ok_free) {
        buf.data = nil;
        buf.len = 0;
        buf.cap = 0;
    }

    ret ok_free;
}

# Ensure capacity for additional bytes beyond current length
# ---
# buf:        buffer to reserve in
# additional: number of additional bytes needed
# ret:        Ok(new capacity) or Err(error message)
pub fun wbuf_reserve(buf: *WriteBuf, additional: usize) Result[usize, str] {
    if (buf == nil) { ret err[usize, str]("buffer is nil"); }

    val need: usize = buf.len + additional;
    if (need < buf.len) { ret err[usize, str]("capacity overflow"); }

    if (buf.cap >= need) {
        ret ok[usize, str](buf.cap);
    }

    var new_cap: usize;
    if (buf.cap == 0) {
        new_cap = 256;
    } or {
        new_cap = buf.cap * 2;
    }

    for (new_cap < need) {
        val prev: usize = new_cap;
        new_cap = new_cap * 2;
        if (new_cap < prev) {
            new_cap = need;
            brk;
        }
    }

    val r: Result[*u8, allocator.AllocError] = allocator.allocator_resize[u8](buf.alloc, buf.data, buf.cap, new_cap);
    if (result_is_err[*u8, allocator.AllocError](r)) { ret err[usize, str](result_unwrap_err[*u8, allocator.AllocError](r)); }

    buf.data = result_unwrap_ok[*u8, allocator.AllocError](r);
    buf.cap = new_cap;

    ret ok[usize, str](buf.cap);
}

# Write a value of type T into the buffer
# ---
# buf:   buffer to write into
# value: value to serialize
# ret:   Ok(new length) or Err(error message)
pub fun wbuf_write[T](buf: *WriteBuf, value: T) Result[usize, str] {
    val sz: usize = $size_of(T);
    val r: Result[usize, str] = wbuf_reserve(buf, sz);
    if (result_is_err[usize, str](r)) { ret err[usize, str](result_unwrap_err[usize, str](r)); }

    var v: T = value;
    mem.raw_copy((buf.data::usize + buf.len)::ptr, (?v)::ptr, sz);
    buf.len = buf.len + sz;
    ret ok[usize, str](buf.len);
}

# Write raw bytes into the buffer
# ---
# buf: buffer to write into
# p:   pointer to source bytes
# len: number of bytes to write
# ret: Ok(new length) or Err(error message)
pub fun wbuf_write_bytes(buf: *WriteBuf, p: *u8, len: usize) Result[usize, str] {
    if (len == 0) { ret ok[usize, str](buf.len); }

    val r: Result[usize, str] = wbuf_reserve(buf, len);
    if (result_is_err[usize, str](r)) { ret err[usize, str](result_unwrap_err[usize, str](r)); }

    mem.raw_copy((buf.data::usize + buf.len)::ptr, p::ptr, len);
    buf.len = buf.len + len;
    ret ok[usize, str](buf.len);
}

# Write a string including its null terminator into the buffer
# ---
# buf: buffer to write into
# s:   string to write
# ret: Ok(new length) or Err(error message)
pub fun wbuf_write_str(buf: *WriteBuf, s: str) Result[usize, str] {
    val slen: usize = str_len(s);
    val total: usize = slen + 1;

    val r: Result[usize, str] = wbuf_reserve(buf, total);
    if (result_is_err[usize, str](r)) { ret err[usize, str](result_unwrap_err[usize, str](r)); }

    mem.raw_copy((buf.data::usize + buf.len)::ptr, s::ptr, slen);
    buf.data[buf.len + slen] = 0;
    buf.len = buf.len + total;
    ret ok[usize, str](buf.len);
}

# Pad with zero bytes to reach an alignment boundary
# ---
# buf:      buffer to align
# boundary: alignment boundary (must be power of two)
# ret:      Ok(new length) or Err(error message)
pub fun wbuf_align(buf: *WriteBuf, boundary: usize) Result[usize, str] {
    val aligned: usize = (buf.len + boundary - 1) & (0 - boundary);
    val pad: usize = aligned - buf.len;
    if (pad == 0) { ret ok[usize, str](buf.len); }

    val r: Result[usize, str] = wbuf_reserve(buf, pad);
    if (result_is_err[usize, str](r)) { ret err[usize, str](result_unwrap_err[usize, str](r)); }

    mem.raw_fill((buf.data::usize + buf.len)::ptr, 0, pad);
    buf.len = buf.len + pad;
    ret ok[usize, str](buf.len);
}

# Overwrite bytes at a given offset without changing length
# ---
# buf:    buffer to patch
# offset: byte offset to write at
# value:  value to write
# ret:    Ok(bytes written) or Err(error message)
pub fun wbuf_patch[T](buf: *WriteBuf, offset: usize, value: T) Result[usize, str] {
    val sz: usize = $size_of(T);
    if (offset + sz > buf.len) { ret err[usize, str]("patch out of bounds"); }

    var v: T = value;
    mem.raw_copy((buf.data::usize + offset)::ptr, (?v)::ptr, sz);
    ret ok[usize, str](sz);
}

# Cursor over an existing byte slice for deserialization
pub rec ReadBuf {
    data: *u8;
    len:  usize;
    pos:  usize;
}

# Wrap existing data as a ReadBuf
# ---
# data: pointer to byte data
# len:  length in bytes
# ret:  a new ReadBuf positioned at offset 0
pub fun rbuf_init(data: *u8, len: usize) ReadBuf {
    var buf: ReadBuf;
    buf.data = data;
    buf.len = len;
    buf.pos = 0;
    ret buf;
}

# Read a value of type T from the buffer and advance position
# ---
# buf: buffer to read from
# ret: Ok(value) or Err(error message)
pub fun rbuf_read[T](buf: *ReadBuf) Result[T, str] {
    val sz: usize = $size_of(T);
    if (buf.pos + sz > buf.len) { ret err[T, str]("eof"); }

    var v: T;
    mem.raw_copy((?v)::ptr, (buf.data::usize + buf.pos)::ptr, sz);
    buf.pos = buf.pos + sz;
    ret ok[T, str](v);
}

# Return a pointer into the buffer at current position and advance
# ---
# buf: buffer to read from
# len: number of bytes to consume
# ret: Ok(pointer) or Err(error message)
pub fun rbuf_read_bytes(buf: *ReadBuf, len: usize) Result[*u8, str] {
    if (buf.pos + len > buf.len) { ret err[*u8, str]("eof"); }

    val p: *u8 = (buf.data::usize + buf.pos)::*u8;
    buf.pos = buf.pos + len;
    ret ok[*u8, str](p);
}

# Read a null-terminated string from the buffer and advance past the NUL
# ---
# buf: buffer to read from
# ret: Ok(string) or Err(error message)
pub fun rbuf_read_str(buf: *ReadBuf) Result[str, str] {
    var i: usize = buf.pos;
    for (i < buf.len) {
        if (buf.data[i] == 0) {
            val s: str = (buf.data::usize + buf.pos)::str;
            buf.pos = i + 1;
            ret ok[str, str](s);
        }
        i = i + 1;
    }
    ret err[str, str]("no null terminator found");
}

# Advance position by n bytes
# ---
# buf: buffer to advance
# n:   number of bytes to skip
# ret: Ok(new position) or Err(error message)
pub fun rbuf_skip(buf: *ReadBuf, n: usize) Result[usize, str] {
    if (buf.pos + n > buf.len) { ret err[usize, str]("eof"); }
    buf.pos = buf.pos + n;
    ret ok[usize, str](buf.pos);
}

# Skip to an alignment boundary
# ---
# buf:      buffer to align
# boundary: alignment boundary (must be power of two)
# ret:      Ok(new position) or Err(error message)
pub fun rbuf_align(buf: *ReadBuf, boundary: usize) Result[usize, str] {
    val aligned: usize = (buf.pos + boundary - 1) & (0 - boundary);
    val skip: usize = aligned - buf.pos;
    if (skip == 0) { ret ok[usize, str](buf.pos); }
    ret rbuf_skip(buf, skip);
}

# Return the number of unread bytes remaining
# ---
# buf: buffer to query
# ret: number of bytes between pos and len
pub fun rbuf_remaining(buf: *ReadBuf) usize {
    ret buf.len - buf.pos;
}

test "bytebuf: round-trip u8" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    val wr: Result[usize, str] = wbuf_write[u8](?wb, 0xAB);
    if (result_is_err[usize, str](wr)) { ret 0; }

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val rr: Result[u8, str] = rbuf_read[u8](?rb);
    if (result_is_err[u8, str](rr)) { ret 0; }
    if (result_unwrap_ok[u8, str](rr) != 0xAB) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: round-trip u16" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u16](?wb, 0xBEEF);

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val rr: Result[u16, str] = rbuf_read[u16](?rb);
    if (result_is_err[u16, str](rr)) { ret 0; }
    if (result_unwrap_ok[u16, str](rr) != 0xBEEF) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

