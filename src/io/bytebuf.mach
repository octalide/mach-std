test "bytebuf: round-trip i64" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[i64](?wb, -9999999999);

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val rr: Result[i64, str] = rbuf_read[i64](?rb);
    if (result_is_err[i64, str](rr)) { ret 0; }
    if (result_unwrap_ok[i64, str](rr) != -9999999999) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: write_bytes and read_bytes round-trip" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    var src: [4]u8 = [4]u8{10, 20, 30, 40};
    val wr: Result[usize, str] = wbuf_write_bytes(?wb, ?src[0], 4);
    if (result_is_err[usize, str](wr)) { ret 0; }
    if (wb.len != 4) { ret 0; }

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val rr: Result[*u8, str] = rbuf_read_bytes(?rb, 4);
    if (result_is_err[*u8, str](rr)) { ret 0; }
    val p: *u8 = result_unwrap_ok[*u8, str](rr);
    if (p[0] != 10) { ret 0; }
    if (p[1] != 20) { ret 0; }
    if (p[2] != 30) { ret 0; }
    if (p[3] != 40) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: write_str and read_str round-trip" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    val wr: Result[usize, str] = wbuf_write_str(?wb, "hello");
    if (result_is_err[usize, str](wr)) { ret 0; }
    if (wb.len != 6) { ret 0; }

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val rr: Result[str, str] = rbuf_read_str(?rb);
    if (result_is_err[str, str](rr)) { ret 0; }
    val s: str = result_unwrap_ok[str, str](rr);
    if (!str_equals(s, "hello")) { ret 0; }
    if (str_len(s) != 5) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: alignment padding" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u8](?wb, 0xFF);
    if (wb.len != 1) { ret 0; }

    val ar: Result[usize, str] = wbuf_align(?wb, 8);
    if (result_is_err[usize, str](ar)) { ret 0; }
    if (wb.len != 8) { ret 0; }

    # verify padding bytes are zero
    if (wb.data[1] != 0) { ret 0; }
    if (wb.data[7] != 0) { ret 0; }

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val rr: Result[u8, str] = rbuf_read[u8](?rb);
    if (result_is_err[u8, str](rr)) { ret 0; }
    if (result_unwrap_ok[u8, str](rr) != 0xFF) { ret 0; }

    val ra: Result[usize, str] = rbuf_align(?rb, 8);
    if (result_is_err[usize, str](ra)) { ret 0; }
    if (rb.pos != 8) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: patch overwrites at offset" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u32](?wb, 0);
    wbuf_write[u32](?wb, 0);
    if (wb.len != 8) { ret 0; }

    val pr: Result[usize, str] = wbuf_patch[u32](?wb, 0, 0xDEADBEEF);
    if (result_is_err[usize, str](pr)) { ret 0; }

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val r1: Result[u32, str] = rbuf_read[u32](?rb);
    if (result_is_err[u32, str](r1)) { ret 0; }
    if (result_unwrap_ok[u32, str](r1) != 0xDEADBEEF) { ret 0; }

    val r2: Result[u32, str] = rbuf_read[u32](?rb);
    if (result_is_err[u32, str](r2)) { ret 0; }
    if (result_unwrap_ok[u32, str](r2) != 0) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: patch out of bounds returns error" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u8](?wb, 1);

    val pr: Result[usize, str] = wbuf_patch[u32](?wb, 0, 42);
    if (result_is_ok[usize, str](pr)) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: multiple sequential writes then reads" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u8](?wb, 1);
    wbuf_write[u16](?wb, 2);
    wbuf_write[u32](?wb, 3);
    wbuf_write[u64](?wb, 4);

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);

    val r1: Result[u8, str] = rbuf_read[u8](?rb);
    if (result_is_err[u8, str](r1)) { ret 0; }
    if (result_unwrap_ok[u8, str](r1) != 1) { ret 0; }

    val r2: Result[u16, str] = rbuf_read[u16](?rb);
    if (result_is_err[u16, str](r2)) { ret 0; }
    if (result_unwrap_ok[u16, str](r2) != 2) { ret 0; }

    val r3: Result[u32, str] = rbuf_read[u32](?rb);
    if (result_is_err[u32, str](r3)) { ret 0; }
    if (result_unwrap_ok[u32, str](r3) != 3) { ret 0; }

    val r4: Result[u64, str] = rbuf_read[u64](?rb);
    if (result_is_err[u64, str](r4)) { ret 0; }
    if (result_unwrap_ok[u64, str](r4) != 4) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: reserve triggers growth" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    val r: Result[usize, str] = wbuf_reserve(?wb, 1000);
    if (result_is_err[usize, str](r)) { ret 0; }
    if (wb.cap < 1000) { ret 0; }
    if (wb.len != 0) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: remaining decreases on read" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u32](?wb, 1);
    wbuf_write[u32](?wb, 2);

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    if (rbuf_remaining(?rb) != 8) { ret 0; }

    rbuf_read[u32](?rb);
    if (rbuf_remaining(?rb) != 4) { ret 0; }

    rbuf_read[u32](?rb);
    if (rbuf_remaining(?rb) != 0) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: read past end returns error" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u8](?wb, 1);

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    val r: Result[u32, str] = rbuf_read[u32](?rb);
    if (result_is_ok[u32, str](r)) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: skip advances position" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u32](?wb, 0xAAAAAAAA);
    wbuf_write[u32](?wb, 0xBBBBBBBB);

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);
    rbuf_skip(?rb, 4);

    val r: Result[u32, str] = rbuf_read[u32](?rb);
    if (result_is_err[u32, str](r)) { ret 0; }
    if (result_unwrap_ok[u32, str](r) != 0xBBBBBBBB) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: write_bytes zero length is noop" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u8](?wb, 1);
    val len_before: usize = wb.len;

    var dummy: [1]u8 = [1]u8{99};
    wbuf_write_bytes(?wb, ?dummy[0], 0);

    if (wb.len != len_before) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: align when already aligned is noop" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write[u64](?wb, 1);
    if (wb.len != 8) { ret 0; }

    val ar: Result[usize, str] = wbuf_align(?wb, 8);
    if (result_is_err[usize, str](ar)) { ret 0; }
    if (wb.len != 8) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: multiple strings round-trip" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);

    wbuf_write_str(?wb, "hello");
    wbuf_write_str(?wb, "world");

    var rb: ReadBuf = rbuf_init(wb.data, wb.len);

    val r1: Result[str, str] = rbuf_read_str(?rb);
    if (result_is_err[str, str](r1)) { ret 0; }
    if (!str_equals(result_unwrap_ok[str, str](r1), "hello")) { ret 0; }

    val r2: Result[str, str] = rbuf_read_str(?rb);
    if (result_is_err[str, str](r2)) { ret 0; }
    if (!str_equals(result_unwrap_ok[str, str](r2), "world")) { ret 0; }

    if (rbuf_remaining(?rb) != 0) { ret 0; }

    wbuf_dnit(?wb);
    ret 1;
}

test "bytebuf: dnit on empty buffer succeeds" {
    var a: allocator.Allocator = allocator.page_allocator();
    var wb: WriteBuf = wbuf_init(?a);
    val ok_d: bool = wbuf_dnit(?wb);
    if (!ok_d) { ret 0; }
    ret 1;
}
