test "parse: f64 simple" {
    val r: Result[f64, str] = parse_f64("3.14");
    if (is_err[f64, str](r)) { ret 0; }
    val v: f64 = unwrap_ok[f64, str](r);
    if (v < 3.13 || v > 3.15) { ret 0; }
    ret 1;
}

test "parse: f64 negative" {
    val r: Result[f64, str] = parse_f64("-2.5");
    if (is_err[f64, str](r)) { ret 0; }
    val v: f64 = unwrap_ok[f64, str](r);
