    val r: Result[f64, str] = parse_f64("1.5e2");
    if (is_err[f64, str](r)) { ret 0; }
    val v: f64 = unwrap_ok[f64, str](r);
    if (v < 149.0 || v > 151.0) { ret 0; }
    ret 1;
}

