# pbits: parse s and return its f64 bit pattern (0xDEADBEEF sentinel on error).
fun pbits(s: str) u64 {
    val r: Result[f64, str] = parse_f64(s);
    if (is_err[f64, str](r)) { ret 0xDEADBEEF; }
    val v: f64 = unwrap_ok[f64, str](r);
    var bits: u64;
    mem.raw_copy(?bits, ?v, 8);
    ret bits;
}

test "parse_f64: correctly-rounded golden bits" {
    if (pbits("0") != 0) { ret 1; }
    if (pbits("1") != 0x3FF0000000000000) { ret 1; }
    if (pbits("-1") != 0xBFF0000000000000) { ret 1; }
    if (pbits("0.5") != 0x3FE0000000000000) { ret 1; }
    if (pbits("1.5") != 0x3FF8000000000000) { ret 1; }
    if (pbits("0.1") != 0x3FB999999999999A) { ret 1; }
    if (pbits("3.141592653589793") != 0x400921FB54442D18) { ret 1; }
    if (pbits("10000000000000000") != 0x4341C37937E08000) { ret 1; }
    if (pbits("1e100") != 0x54B249AD2594C37D) { ret 1; }
    if (pbits("1.7976931348623157e308") != 0x7FEFFFFFFFFFFFFF) { ret 1; }
    if (pbits("2.2250738585072014e-308") != 0x0010000000000000) { ret 1; }
    if (pbits("5e-324") != 1) { ret 1; }
    ret 0;
}

test "parse_f64: special and out-of-range" {
    if (pbits("-0") != 0x8000000000000000) { ret 1; }
    if (pbits("inf") != 0x7FF0000000000000) { ret 1; }
    if (pbits("-inf") != 0xFFF0000000000000) { ret 1; }
    if (pbits("nan") != 0x7FF8000000000000) { ret 1; }
    if (pbits("1e400") != 0x7FF0000000000000) { ret 1; }
    if (pbits("1e-400") != 0) { ret 1; }
    ret 0;
}
