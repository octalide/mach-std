test "parse: i64 min value" {
    val r: Result[i64, str] = parse_i64("-9223372036854775808", 10);
    if (is_err[i64, str](r)) { ret 0; }
    if (unwrap_ok[i64, str](r) != -9223372036854775808) { ret 0; }
    ret 1;
}

