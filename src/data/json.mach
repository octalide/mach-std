    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    var buf: [16]u8;
    val n: usize = emit(?v, ?buf[0], 16);
    if (n != 3) { ret 1; }
    if (buf[0] != '1') { ret 1; }
    if (buf[1] != '2') { ret 1; }
    if (buf[2] != '3') { ret 1; }
    ret 0;
}

test "json: emit true" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "true";
