    val v: Value = unwrap_ok[Value, str](r);
    var buf: [16]u8;
    val n: usize = emit(?v, ?buf[0], 16);
    if (n != 4) { ret 1; }
    if (buf[0] != 't') { ret 1; }
    if (buf[3] != 'e') { ret 1; }
    ret 0;
}

test "json: roundtrip array" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "[1,2,3]";
    val r: Result[Value, str] = parse(src::*u8, 7, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    var buf: [32]u8;
    val n: usize = emit(?v, ?buf[0], 32);
    if (n != 7) { ret 1; }
    if (buf[0] != '[') { ret 1; }
    if (buf[1] != '1') { ret 1; }
    if (buf[2] != ',') { ret 1; }
    if (buf[3] != '2') { ret 1; }
    if (buf[6] != ']') { ret 1; }
    ret 0;
}

test "json: roundtrip object keys" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "{\"a\":1,\"b\":2}";
    val r: Result[Value, str] = parse(src::*u8, 13, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    var buf: [32]u8;
    val n: usize = emit(?v, ?buf[0], 32);
    if (n != 13) { ret 1; }
    var i: usize = 0;
    for (i < 13) {
        if (buf[i] != src[i]::u8) { ret 1; }
        i = i + 1;
    }
    ret 0;
}

test "json: whitespace tolerance" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "  { \"a\" : 1 } ";
    val r: Result[Value, str] = parse(src::*u8, 14, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    if (v.kind != OBJECT) { ret 1; }
    if (v.count != 1) { ret 1; }
    ret 0;
}
