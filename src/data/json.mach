    val src: str = "{}";
    val r: Result[Value, str] = parse(src::*u8, 2, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    if (v.kind != OBJECT) { ret 1; }
    if (v.count != 0) { ret 1; }
    ret 0;
}

test "json: parse object with entry" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "{\"a\":1}";
    val r: Result[Value, str] = parse(src::*u8, 7, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    if (v.kind != OBJECT) { ret 1; }
    if (v.count != 1) { ret 1; }
    if (v.children[0].num_val != 1) { ret 1; }
    ret 0;
}

test "json: parse nested object with array" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "{\"x\":[1,2]}";
    val r: Result[Value, str] = parse(src::*u8, 11, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    if (v.kind != OBJECT) { ret 1; }
    if (v.count != 1) { ret 1; }
    val arr: *Value = ?v.children[0];
    if (arr.kind != ARRAY) { ret 1; }
    if (arr.count != 2) { ret 1; }
    if (arr.children[0].num_val != 1) { ret 1; }
    if (arr.children[1].num_val != 2) { ret 1; }
    ret 0;
}

test "json: value_find on object" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "{\"a\":1,\"b\":2}";
    val r: Result[Value, str] = parse(src::*u8, 13, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    val found: *Value = value_find(?v, "b");
    if (found == nil) { ret 1; }
    if (found.num_val != 2) { ret 1; }
    val missing: *Value = value_find(?v, "z");
    if (missing != nil) { ret 1; }
    ret 0;
}

test "json: emit null" {
    var a: allo.Allocator;
    page.make(?a);
    val src: str = "null";
    val r: Result[Value, str] = parse(src::*u8, 4, ?a);
    if (is_err[Value, str](r)) { ret 1; }
    val v: Value = unwrap_ok[Value, str](r);
    var buf: [16]u8;
    val n: usize = emit(?v, ?buf[0], 16);
    if (n != 4) { ret 1; }
    if (buf[0] != 'n') { ret 1; }
    if (buf[1] != 'u') { ret 1; }
    if (buf[2] != 'l') { ret 1; }
    if (buf[3] != 'l') { ret 1; }
    ret 0;
}

test "json: emit number" {
    var a: allo.Allocator;
